@{
    ViewData["Title"] = "Map";
}
<link rel="stylesheet" href="~/css/map.css" />

<div class="container-fluid mt-4 map-page px-4">
    <h2 class="map-title">Map</h2>

    <div class="map-toolbar">
        <div class="map-search-group">
            <input id="searchBox"
                   type="text"
                   class="form-control map-search-input"
                   placeholder="Search for a specific location..." />

            <button id="searchBtn" class="map-search-btn" type="button">
                Search
            </button>
        </div>

        <button id="myLocationBtn" class="map-location-btn" type="button">
            My Location
        </button>

        <input id="closestCount"
               type="number"
               class="form-control"
               placeholder="How many shelters?"
               min="1"
               style="width:200px; margin-left:10px;" />

        <select id="travelMode"
                class="form-control"
                style="width:180px; margin-left:10px;">
            <option value="WALKING">Walking</option>
            <option value="DRIVING">Driving</option>
        </select>

        <button id="btnClosest" class="btn btn-warning" style="margin-left:10px;">
            Closest Shelters
        </button>
        <button id="btnClear" class="btn btn-danger" style="margin-left:10px;">
            Clear Map
        </button>
    </div>

    <div class="map-container">
        <div class="map-layout">
            <div class="map-map-area">
                <div class="map-legend">
                    <div class="map-legend-title">Map Key</div>

                    <div class="map-legend-item">
                        <span class="legend-color red"></span>
                        Real-time alert (last 15 minutes)
                    </div>

                    <div class="map-legend-item">
                        <span class="legend-color yellow"></span>
                        Alert in last 24 hours
                    </div>
                    <div class="map-legend-item">
                        <img src="https://maps.google.com/mapfiles/ms/icons/red-dot.png"
                             alt="Shelter marker"
                             class="legend-marker-icon" />
                        Shelter
                    </div>
                </div>

                <div id="map"></div>
            </div>

            <div id="shelterPanel" class="shelter-panel">
                <h4>Shelter Details</h4>
                <p>Click a shelter on the map to view details.</p>
            </div>
        </div>
    </div>
</div>

<script>
    const loggedInUser = '@Context.Session.GetString("UserName")';
</script>

<script>
    let map;
    let userMarker;
    let autocomplete;
    let geocoder;
    let infoWindow;
    let shelterMarkers = [];
    let riskCircles = {};
    let userLocation = null;

    let closestListData = [];
    let closestShelterMarkers = [];

    let directionsService;
    let directionsRenderer;
    let selectedShelterIndex = null;

        function isUserLoggedIn() {
        return loggedInUser && loggedInUser !== '';
    }
        function clearMap() {
        // ❌ remove route
        directionsRenderer.setDirections({ routes: [] });

        // ❌ remove closest markers
        closestShelterMarkers.forEach(m => m.setMap(null));
        closestShelterMarkers = [];

        // ❌ clear selection
        selectedShelterIndex = null;

        // ❌ close info window
        infoWindow.close();

        // ❌ reset side panel
        document.getElementById("shelterPanel").innerHTML = `
            <h4>Shelter Details</h4>
            <p>Click a shelter on the map to view details.</p>
        `;
    }
    function initMap() {
        const defaultCenter = { lat: 31.2518, lng: 34.7913 };
        document.getElementById("btnClear").onclick = clearMap;
        map = new google.maps.Map(document.getElementById("map"), {
            center: defaultCenter,
            zoom: 8,
            mapTypeControl: false,
            streetViewControl: false,
            fullscreenControl: false
        });

        geocoder = new google.maps.Geocoder();
        infoWindow = new google.maps.InfoWindow();

        directionsService = new google.maps.DirectionsService();
           directionsRenderer = new google.maps.DirectionsRenderer({
        suppressMarkers: true,
        preserveViewport: true,
        polylineOptions: {
            strokeColor: "#000000",
            strokeOpacity: 1.0,
            strokeWeight: 7
        }
    });
        directionsRenderer.setMap(map);

        userMarker = new google.maps.Marker({
            position: defaultCenter,
            map: map,
            icon: "https://maps.google.com/mapfiles/ms/icons/blue-dot.png",
            title: "Your location"
        });

        const input = document.getElementById("searchBox");
        const searchBtn = document.getElementById("searchBtn");
        const myLocationBtn = document.getElementById("myLocationBtn");

        autocomplete = new google.maps.places.Autocomplete(input);
        autocomplete.addListener("place_changed", function () {
            const place = autocomplete.getPlace();
            if (!place.geometry) return;
            moveToLocation(place.geometry.location, "Selected location");
        });

        searchBtn.onclick = () => {
            const address = input.value.trim();
            if (!address) return;

            geocoder.geocode({ address }, (res, status) => {
                if (status === "OK") {
                    moveToLocation(res[0].geometry.location, "Selected location");
                } else {
                    alert("Location not found");
                }
            });
        };

        input.addEventListener("keydown", function (e) {
            if (e.key === "Enter") {
                e.preventDefault();
                searchBtn.click();
            }
        });

        myLocationBtn.onclick = () => {
            navigator.geolocation.getCurrentPosition(
                pos => {
                    moveToLocation(
                        { lat: pos.coords.latitude, lng: pos.coords.longitude },
                        "You are here"
                    );
                },
                () => alert("Cannot get location.")
            );
        };

        document.getElementById("btnClosest").onclick = loadClosestShelters;

        document.getElementById("travelMode").addEventListener("change", function () {
            if (selectedShelterIndex !== null) {
                const s = closestListData[selectedShelterIndex];
                drawRealRouteToShelter(s);
            }
        });

        loadShelters();
        loadCityRisks();
        setInterval(loadCityRisks, 5000);
    }

    function moveToLocation(location, title) {
        map.setCenter(location);
        map.setZoom(12);
        userMarker.setPosition(location);
        userMarker.setTitle(title);

        userLocation = {
            lat: typeof location.lat === "function" ? location.lat() : location.lat,
            lng: typeof location.lng === "function" ? location.lng() : location.lng
        };

        selectedShelterIndex = null;
        directionsRenderer.setDirections({ routes: [] });

        infoWindow.setContent(`<strong>${title}</strong>`);
        infoWindow.open(map, userMarker);
    }

    async function loadClosestShelters() {
        if (!userLocation) {
            alert("Please choose a location first.");
            return;
        }

        let count = parseInt(document.getElementById("closestCount").value);
        if (!count || count < 1) count = 10;

        try {
            const response = await fetch("/Map/GetClosestShelters", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                    latitude: userLocation.lat,
                    longitude: userLocation.lng,
                    count: count
                })
            });

            if (!response.ok) {
                throw new Error("Failed to load closest shelters");
            }

            const data = await response.json();
            closestListData = data;
            renderClosestList(data);
        } catch (err) {
            console.error(err);
            alert("Could not load closest shelters.");
        }
    }

    function renderClosestList(list) {
        const panel = document.getElementById("shelterPanel");

        closestShelterMarkers.forEach(m => m.setMap(null));
        closestShelterMarkers = [];

        let html = `
            <h4>Closest ${list.length} Shelters</h4>
            <p style="margin-bottom:10px;">Select a shelter to see the real route.</p>
            <ul style="padding-left:0; list-style:none;">
        `;

        const purpleIcon = {
            url: "https://maps.google.com/mapfiles/ms/icons/purple-dot.png"
        };

        list.forEach((s, i) => {
            let d = s.distance < 1000
                ? `${Math.round(s.distance)} m`
                : `${(s.distance / 1000).toFixed(2)} km`;

            const marker = new google.maps.Marker({
                position: { lat: s.lat, lng: s.lng },
                map: map,
                icon: purpleIcon,
                zIndex: 9999,
                title: s.name
            });

            closestShelterMarkers.push(marker);

            marker.addListener("click", () => {
                focusClosest(i);
            });

            html += `
                <li onclick="focusClosest(${i})"
                    style="padding:8px; cursor:pointer; border-bottom:1px solid #ccc;">
                    <strong>${s.name}</strong> — ${d}
                </li>
            `;
        });

        html += "</ul>";
        panel.innerHTML = html;
    }

    function focusClosest(i) {
        const s = closestListData[i];
        selectedShelterIndex = i;

        const shelterPos = { lat: s.lat, lng: s.lng };

        map.setCenter(shelterPos);
        map.setZoom(15);

        infoWindow.setContent(`<strong>${s.name}</strong>`);
        infoWindow.setPosition(shelterPos);
        infoWindow.open(map);

        drawRealRouteToShelter(s);
    }

    function drawRealRouteToShelter(shelter) {
        if (!userLocation) {
            alert("Please choose a location first.");
            return;
        }

        const travelModeValue = document.getElementById("travelMode").value;

        directionsService.route(
            {
                origin: userLocation,
                destination: { lat: shelter.lat, lng: shelter.lng },
                travelMode: google.maps.TravelMode[travelModeValue],
                drivingOptions: travelModeValue === "DRIVING" ? {
                    departureTime: new Date(),
                    trafficModel: "bestguess"
                } : undefined
            },
            (result, status) => {
                if (status !== "OK") {
                    console.error("Directions failed:", status);
                    alert("Could not calculate route.");
                    return;
                }

                directionsRenderer.setDirections(result);
                showRouteDetails(result, shelter, travelModeValue);
            }
        );
    }

    function showRouteDetails(result, shelter, travelModeValue) {
        const route = result.routes[0];
        const leg = route.legs[0];

        const routeDistanceText = leg.distance ? leg.distance.text : "N/A";
        const routeDurationText = leg.duration ? leg.duration.text : "N/A";

        let bestCase = "";
        let worstCase = "";
        let extraNote = "";

        if (travelModeValue === "DRIVING") {
            const baseSeconds = leg.duration ? leg.duration.value : 0;
            const bestMinutes = (baseSeconds / 60) * 0.9;
            const worstMinutes = (baseSeconds / 60) * 1.35;

            bestCase = `${bestMinutes.toFixed(1)} min`;
            worstCase = `${worstMinutes.toFixed(1)} min`;
            extraNote = "Driving case may vary due to roads and traffic.";
        } else {
            const meters = leg.distance ? leg.distance.value : 0;
            const bestMinutes = (meters / 1.6 / 60);
            const worstMinutes = (meters / 1.0 / 60);

            bestCase = `${bestMinutes.toFixed(1)} min`;
            worstCase = `${worstMinutes.toFixed(1)} min`;
            extraNote = "Walking case depends on pace and road access.";
        }
        
        document.getElementById("shelterPanel").innerHTML =
        "<h4>Shelter Route Details</h4>" +
        "<p><strong>Name:</strong> " + shelter.name + "</p>" +
        "<p><strong>Travel mode:</strong> " + travelModeValue + "</p>" +
        "<p><strong>Route distance:</strong> " + routeDistanceText + "</p>" +
        "<p><strong>Google estimated time:</strong> " + routeDurationText + "</p>" +
        "<p><strong>Best case:</strong> " + bestCase + "</p>" +
        "<p><strong>Worst case:</strong> " + worstCase + "</p>" +
        "<p><strong>Latitude:</strong> " + shelter.lat + "</p>" +
        "<p><strong>Longitude:</strong> " + shelter.lng + "</p>" +
        "<p style='margin-top:10px; color:#555;'>" + extraNote + "</p>" +

        getFeedbackSection(shelter.id);

        loadFeedback(shelter.id);
    
    }

        async function loadShelters() {
        const response = await fetch('/api/shelters');
        const shelters = await response.json();

        shelters.forEach(shelter => {
            const marker = new google.maps.Marker({
                position: { lat: shelter.latitude, lng: shelter.longitude },
                map: map,
                icon: "https://maps.google.com/mapfiles/ms/icons/red-dot.png"
            });

            marker.shelterId = shelter.id;

            marker.addListener("click", () => {
                let html = "";
                html += "<h4>Shelter Details</h4>";
                html += "<p><strong>Name:</strong> " + shelter.name + "</p>";
                html += "<p><strong>Latitude:</strong> " + shelter.latitude + "</p>";
                html += "<p><strong>Longitude:</strong> " + shelter.longitude + "</p>";
                html += getFeedbackSection(shelter.id);

                document.getElementById("shelterPanel").innerHTML = html;

                loadFeedback(shelter.id);
            });

            shelterMarkers.push(marker);
        });

        const params = new URLSearchParams(window.location.search);
        const shelterId = params.get("shelterId");

        if (shelterId) {
            focusShelterById(parseInt(shelterId));
        }
    }



        async function loadCityRisks() {
        const response = await fetch('/Map/GetCityRisks');
        const cities = await response.json();

        cities.forEach(city => {
            if (!city.latitude || !city.longitude) return;

            // ❌ remove green (low risk)
            if (city.color === "green") {
                if (riskCircles[city.cityName]) {
                    riskCircles[city.cityName].setMap(null);
                    delete riskCircles[city.cityName];
                }
                return;
            }

            // normalize orange/yellow (your backend uses "orange")
            let color = city.color === "orange" ? "#FFA500" : city.color;

            if (!riskCircles[city.cityName]) {
                riskCircles[city.cityName] = new google.maps.Circle({
                    strokeColor: color,
                    fillColor: color,
                    strokeOpacity: 0.5,   // softer border
                    fillOpacity: 0.18,    // lighter fill (so route is visible)
                    map: map,
                    center: { lat: city.latitude, lng: city.longitude },
                    radius: 2500
                });
            } else {
                riskCircles[city.cityName].setOptions({
                    strokeColor: color,
                    fillColor: color
                });
            }
        });
    }


            function getFeedbackSection(shelterId) {

        let inputPart = "";

        if (isUserLoggedIn()) {
            inputPart =
                '<textarea id="feedbackInput" class="form-control mt-2" placeholder="Write your feedback..."></textarea>' +
                '<button onclick="sendFeedback(' + shelterId + ')" class="btn btn-primary mt-2">Send</button>';
        } else {
            inputPart =
                '<p style="color:gray;">You must be logged in to write feedback.</p>' +
                '<a href="/Account/Login?returnUrl=/Map/Index?shelterId=' + shelterId + '" class="btn btn-outline-primary btn-sm">Login</a>' +
                '<a href="/Account/Register?returnUrl=/Map/Index?shelterId=' + shelterId + '" class="btn btn-outline-secondary btn-sm">Sign Up</a>';
        }

        return '<hr/>' +
               '<h5>Feedback</h5>' +
               '<div id="feedbackList">Loading feedback...</div>' +
               inputPart;
    }


        async function loadFeedback(shelterId) {
        try {
            const res = await fetch(`/Feedback/GetByShelter?shelterId=${shelterId}`);
            const data = await res.json();

            let html = "";

            if (data.length === 0) {
                html = "<p>No feedback yet</p>";
            } else {
                data.forEach(f => {
                    html += `
                        <div style="border-bottom:1px solid #ccc; margin-bottom:5px;">
                            <strong>${f.userName}</strong>
                            <p>${f.comment}</p>
                        </div>
                    `;
                });
            }

            document.getElementById("feedbackList").innerHTML = html;

        } catch (err) {
            console.error(err);
            document.getElementById("feedbackList").innerHTML = "Error loading feedback";
        }
    }


        async function sendFeedback(shelterId) {
        const input = document.getElementById("feedbackInput");
        const text = input.value.trim();

        if (!text) {
            alert("Write something first!");
            return;
        }

        await fetch("/Feedback/Add", {
            method: "POST",
            headers: {
                "Content-Type": "application/json"
            },
            body: JSON.stringify({
                shelterId: shelterId,
                comment: text
            })
        });

        input.value = "";
        loadFeedback(shelterId);
    }

            function focusShelterById(id) {
        const marker = shelterMarkers.find(m => m.shelterId === id);

        if (marker) {
            google.maps.event.trigger(marker, "click");
        } else {
            console.log("Marker not found for id:", id);
        }
    }


    window.initMap = initMap;
</script>

<script async defer
        src="https://maps.googleapis.com/maps/api/js?key=AIzaSyAuiZcDNCGOmwM7OSjNncN7yrjIjcRMzJk&libraries=places,geometry&callback=initMap">
</script>