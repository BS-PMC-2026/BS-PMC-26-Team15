@model List<SamiSpot.Models.User>

<h2>All Registered Users</h2>

<a asp-action="AddUser" asp-route-role="User" class="btn btn-primary mb-3">
    + Add User
</a>

@if (!Model.Any())
{
    <div class="alert alert-info">
        No users found.
    </div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>ID</th>
                <th>User Name</th>
                <th>Email</th>
                <th>Role</th>
                <th>Status</th> 
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.Id</td>
                    <td>@user.UserName</td>
                    <td>@user.Email</td>
                    <td>@user.RoleType</td>

                    <td>
                        @if (user.IsActive)
                        {
                            <span class="text-success">Active</span>
                        }
                        else
                        {
                            <span class="text-danger">Inactive</span>
                        }
                    </td>

                    <td>
                        @if (user.IsActive)
                        {
                            <a asp-action="DeactivateUser" asp-route-id="@user.Id"
                               class="btn btn-warning btn-sm">
                                Deactivate
                            </a>
                        }
                        else
                        {
                            <a asp-action="ActivateUser" asp-route-id="@user.Id"
                               class="btn btn-success btn-sm">
                                Activate
                            </a>
                        }

                        <a asp-action="DeleteUser" asp-route-id="@user.Id"
                           class="btn btn-danger btn-sm"
                           onclick="return confirm('Are you sure you want to delete this user?');">
                            Delete
                        </a>

                    </td>
                </tr>
            }
        </tbody>
    </table>
}