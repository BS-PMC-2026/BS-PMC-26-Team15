@model List<SamiSpot.Models.User>

<style>
    body {
        background: #f4fbfd;
    }

    .users-page {
        width: 100%;
        padding: 40px 60px;
        margin: 0;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 15px;
        flex-wrap: wrap;
        margin-bottom: 30px;
    }

    .page-title {
        font-size: 38px;
        font-weight: 800;
        color: #2c4a52;
        margin: 0;
    }

    .page-subtitle {
        color: #5a7c84;
        font-size: 17px;
        margin-top: 5px;
    }

    .add-btn {
        background: #4bbfd3;
        color: white;
        border: none;
        border-radius: 30px;
        padding: 12px 24px;
        text-decoration: none;
        font-weight: 800;
        box-shadow: 0 8px 18px rgba(75,191,211,0.25);
    }

        .add-btn:hover {
            background: #36aeca;
            color: white;
        }

    .table-scroll {
        width: 100%;
        overflow-x: auto;
    }

    .users-table {
        width: 100%;
        border-collapse: collapse;
    }

        .users-table thead th {
            background: #eaf9fc;
            color: #2c4a52;
            font-weight: 800;
            padding: 16px;
            border-bottom: 2px solid #cdeff5;
        }

        .users-table tbody tr {
            background: #ffffff;
            transition: 0.2s;
        }

            .users-table tbody tr:hover {
                background: #f9feff;
                box-shadow: 0 6px 18px rgba(0,0,0,0.05);
            }

        .users-table tbody td {
            background: #ffffff;
            padding: 18px 16px;
            color: #3c5c63;
            border-bottom: 1px solid #dceff3;
            vertical-align: middle;
        }

    .id-cell {
        font-weight: 800;
        color: #4bbfd3;
    }

    .status-active {
        color: #198754;
        font-weight: 800;
    }

    .status-inactive {
        color: #dc3545;
        font-weight: 800;
    }

    .action-btn {
        border-radius: 20px;
        padding: 6px 14px;
        font-weight: 700;
        margin-right: 5px;
    }

    .empty-box {
        background: #eaf9fc;
        border-left: 5px solid #4bbfd3;
        padding: 20px;
        color: #2c4a52;
        border-radius: 10px;
    }

    @@media (max-width: 768px) {
        .users-page {
            padding: 25px;
        }

        .users-table {
            min-width: 800px;
        }
    }
</style>

<div class="users-page">

    <div class="page-header">
        <div>
            <h2 class="page-title"> All Registered Users</h2>
            <p class="page-subtitle">Manage user accounts, status, and access.</p>
        </div>

        <a asp-action="AddUser" asp-route-role="User" class="add-btn">
            + Add User
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-box">
            No users found.
        </div>
    }
    else
    {
        <div class="table-scroll">
            <table class="users-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>User Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td class="id-cell">@user.Id</td>
                            <td>@user.UserName</td>
                            <td>@user.Email</td>
                            <td>@user.RoleType</td>

                            <td>
                                @if (user.IsActive)
                                {
                                    <span class="status-active">Active</span>
                                }
                                else
                                {
                                    <span class="status-inactive">Inactive</span>
                                }
                            </td>

                            <td>
                                @if (user.IsActive)
                                {
                                    <form asp-action="DeactivateUser" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@user.Id" />
                                        <button type="submit" class="btn btn-warning btn-sm action-btn">
                                            Deactivate
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <form asp-action="ActivateUser" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@user.Id" />
                                        <button type="submit" class="btn btn-success btn-sm action-btn">
                                            Activate
                                        </button>
                                    </form>
                                }

                                <form asp-action="DeleteUser" method="post" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@user.Id" />
                                    <button type="submit" class="btn btn-danger btn-sm action-btn"
                                            onclick="return confirm('Are you sure you want to delete this user?');">
                                        Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

</div>