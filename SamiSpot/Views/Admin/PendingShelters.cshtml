@model List<SamiSpot.Models.ContributorShelter>

@{
    ViewData["Title"] = "Pending Shelters";
}

<div class="container mt-4">
    <h2 class="mb-4">Pending Shelter Approvals</h2>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info">No pending shelters found.</div>
    }
    else
    {
        <div class="row">
            @foreach (var shelter in Model)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card shadow-sm h-100">
                        <div class="card-body d-flex flex-column">

                            <h5 class="card-title mb-2">@shelter.Name</h5>

                            <p class="mb-1">
                                <strong>Contributor:</strong> @shelter.UserId
                            </p>

                            <p class="mb-3">
                                <strong>Created:</strong> @shelter.CreatedAt.ToString("yyyy-MM-dd HH:mm")
                            </p>

                            <div class="mt-auto">
                                <a href="/Admin/ShelterDetails/@shelter.Id"
                                   class="btn btn-primary btn-sm w-100">
                                    View Details
                                </a>
                            </div>

                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>