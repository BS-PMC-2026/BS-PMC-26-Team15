@model SamiSpot.Models.ContributorShelter

@{
    ViewData["Title"] = "Shelter Details";
}

<style>
    body {
        background: #f4fbfd;
    }

    .details-wrapper {
        max-width: 1180px;
        margin: 35px auto;
        padding: 0 15px;
    }

    .details-shell {
        background: #ffffff;
        border: 1px solid #d6f2f7;
        border-radius: 30px;
        box-shadow: 0 14px 35px rgba(0,0,0,0.07);
        overflow: hidden;
    }

    .details-top {
        background: linear-gradient(135deg, #4bbfd3, #eaf9fc);
        padding: 36px;
    }

        .details-top h2 {
            font-size: 38px;
            font-weight: 800;
            color: #2c4a52;
            margin: 0;
        }

        .details-top p {
            color: #3c5c63;
            margin: 8px 0 0;
        }

    .details-body {
        display: grid;
        grid-template-columns: 320px 1fr;
    }

    .summary-panel {
        background: #eaf9fc;
        padding: 30px;
        border-right: 1px solid #d6f2f7;
    }

    .shelter-avatar {
        width: 90px;
        height: 90px;
        border-radius: 24px;
        background: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 44px;
        box-shadow: 0 8px 18px rgba(0,0,0,0.08);
        margin-bottom: 18px;
    }

    .shelter-name {
        color: #2c4a52;
        font-size: 28px;
        font-weight: 800;
        margin-bottom: 14px;
    }

    .summary-text {
        color: #3c5c63;
        margin-bottom: 10px;
    }

    .main-panel {
        padding: 30px;
    }

    .detail-row {
        display: flex;
        gap: 14px;
        padding: 16px 0;
        border-bottom: 1px solid #edf7f9;
    }

    .detail-icon {
        width: 42px;
        height: 42px;
        border-radius: 14px;
        background: #eaf9fc;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 21px;
        flex-shrink: 0;
    }

    .detail-label {
        color: #2c4a52;
        font-weight: 800;
        margin-bottom: 4px;
    }

    .detail-value {
        color: #3c5c63;
    }

    .section-title {
        color: #2c4a52;
        font-size: 24px;
        font-weight: 800;
        margin: 30px 0 16px;
    }

    .image-card img {
        height: 230px;
        width: 100%;
        object-fit: cover;
        border-radius: 20px;
        border: 1px solid #d6f2f7;
        box-shadow: 0 8px 18px rgba(0,0,0,0.07);
    }

    .empty-box {
        background: #eaf9fc;
        border: 1px solid #d6f2f7;
        border-radius: 16px;
        padding: 16px;
        color: #3c5c63;
    }

    .action-area {
        margin-top: 28px;
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .approve-btn,
    .reject-btn,
    .back-btn {
        border-radius: 30px;
        padding: 11px 24px;
        font-weight: 800;
    }

    @@media (max-width: 900px) {
        .details-body {
            grid-template-columns: 1fr;
        }

        .summary-panel {
            border-right: none;
            border-bottom: 1px solid #d6f2f7;
        }
    }
</style>

<div class="details-wrapper">
    <div class="details-shell">

        <div class="details-top">
            <h2>🛡️ Admin Shelter Review</h2>
            <p>Review submitted shelter information before approval or rejection.</p>
        </div>

        <div class="details-body">

            <div class="summary-panel">
                <div class="shelter-avatar">🏠</div>

                <div class="shelter-name">@Model.Name</div>

                <div class="summary-text"><strong>Status:</strong> @Model.Status</div>
                <div class="summary-text"><strong>Contributor:</strong> @Model.UserId</div>
                <div class="summary-text"><strong>Available:</strong> @(Model.IsAvailable ? "Yes" : "No")</div>
                <div class="summary-text"><strong>Size:</strong> @(Model.Size.HasValue? Model.Size.ToString() : "Not specified")</div>
            </div>

            <div class="main-panel">

                <div class="detail-row">
                    <div class="detail-icon">📍</div>
                    <div>
                        <div class="detail-label">Address</div>
                        <div class="detail-value">@Model.Address</div>
                    </div>
                </div>

                <div class="detail-row">
                    <div class="detail-icon">📝</div>
                    <div>
                        <div class="detail-label">Description</div>
                        <div class="detail-value">@Model.Description</div>
                    </div>
                </div>

                <div class="detail-row">
                    <div class="detail-icon">📅</div>
                    <div>
                        <div class="detail-label">Created At</div>
                        <div class="detail-value">@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</div>
                    </div>
                </div>

                <div class="detail-row">
                    <div class="detail-icon">🗺️</div>
                    <div>
                        <div class="detail-label">Location</div>
                        <div class="detail-value">@Model.Latitude , @Model.Longitude</div>
                    </div>
                </div>

                <div class="section-title">Images</div>

                @if (Model.Images != null && Model.Images.Count > 0)
                {
                    <div class="row">
                        @foreach (var image in Model.Images)
                        {
                            <div class="col-md-4 mb-3 image-card">
                                <img src="@image.ImageUrl" />
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-box">No images uploaded.</div>
                }

                <div class="action-area">

                    <form asp-action="ApproveShelter" asp-controller="Admin" method="post" style="display:inline;">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-success approve-btn"
                                onclick="return confirm('Approve this shelter? It will appear on the map.');">
                            Approve
                        </button>
                    </form>

                    <form asp-action="RejectShelter" asp-controller="Admin" method="post" style="display:inline;">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-danger reject-btn"
                                onclick="return confirm('Reject this shelter?');">
                            Reject
                        </button>
                    </form>

                    <a asp-controller="Account" asp-action="Admindashboard" class="btn btn-secondary back-btn">Back</a>

                </div>

            </div>
        </div>
    </div>
</div>