@model SamiSpot.Models.User

<style>
    body {
        background: linear-gradient(135deg, #eaf9fc, #f4fbfd);
    }

    .auth-container {
        min-height: 90vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 30px 15px;
    }

    .auth-card {
        width: 100%;
        max-width: 460px;
        background: #ffffff;
        border: 1px solid #d6f2f7;
        border-radius: 28px;
        padding: 40px 35px;
        box-shadow: 0 20px 50px rgba(0,0,0,0.08);
    }

    .auth-title {
        font-size: 30px;
        font-weight: 800;
        color: #2c4a52;
        text-align: center;
        margin-bottom: 28px;
    }

    .form-label {
        color: #2c4a52;
        font-weight: 700;
    }

    .form-control {
        border-radius: 14px;
        border: 1px solid #d6f2f7;
        padding: 12px 14px;
    }

        .form-control:focus {
            border-color: #4bbfd3;
            box-shadow: 0 0 0 0.2rem rgba(75,191,211,0.18);
        }

    .password-note {
        background: #eaf9fc;
        border: 1px solid #d6f2f7;
        border-radius: 14px;
        padding: 12px 14px;
        color: #5a7c84;
        font-size: 13px;
        margin-bottom: 18px;
    }

    .auth-btn {
        width: 100%;
        background: linear-gradient(135deg, #4bbfd3, #36aeca);
        border: none;
        color: white;
        border-radius: 30px;
        padding: 13px;
        font-weight: 800;
        box-shadow: 0 8px 18px rgba(75,191,211,0.25);
        transition: 0.2s;
    }

        .auth-btn:hover {
            color: white;
            transform: translateY(-2px);
        }
</style>

<div class="auth-container">
    <div class="auth-card">

        <h3 class="auth-title">
            Add @(Model.RoleType == "Contributor" ? "Contributor" : "User")
        </h3>

        <form asp-action="AddUser" method="post">

            <div asp-validation-summary="All" class="text-danger"></div>

            <div class="mb-3">
                <label class="form-label">Username</label>
                <input asp-for="UserName" class="form-control" placeholder="Enter username..." />
            </div>

            <div class="mb-3">
                <label class="form-label">Email</label>
                <input asp-for="Email" class="form-control" placeholder="Enter email..." />
            </div>

            <div class="mb-3">
                <label class="form-label">Password</label>
                <input asp-for="Password" type="password" class="form-control" placeholder="Enter password..." />
            </div>

            <div class="mb-3">
                <label class="form-label">Confirm Password</label>
                <input name="ConfirmPassword" type="password" class="form-control" placeholder="Confirm password..." />
            </div>

            <p class="password-note">
                🔐 Password must be at least 8 characters, include uppercase, lowercase and number.
            </p>

            <input type="hidden" asp-for="RoleType" />

            <button type="submit" class="btn auth-btn">
                Add @(Model.RoleType == "Contributor" ? "Contributor" : "User")
            </button>

        </form>

    </div>
</div>