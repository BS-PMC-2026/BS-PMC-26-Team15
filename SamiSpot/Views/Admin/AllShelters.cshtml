@model List<SamiSpot.Models.ContributorShelter>

@{
    ViewData["Title"] = "All Submitted Shelters";
}

<div class="container mt-4">
    <h2 class="mb-4">All Submitted Shelters</h2>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info">No submitted shelters found.</div>
    }
    else
    {
        <table class="table table-bordered table-hover">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Shelter Name</th>
                    <th>Status</th>
                    <th>Date Added</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var shelter in Model)
                {
                    <tr>
                        <td>@shelter.Id</td>
                        <td>@shelter.Name</td>

                        <td>
                            @if (shelter.Status == "Approved")
                            {
                                <span class="badge bg-success">Approved</span>
                            }
                            else if (shelter.Status == "Pending")
                            {
                                <span class="badge bg-warning text-dark">Pending</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Rejected</span>
                            }
                        </td>

                        <td>@shelter.CreatedAt.ToString("dd/MM/yyyy")</td>

                        <td>
                            <a href="/Admin/ShelterDetails/@shelter.Id" class="btn btn-sm btn-primary">View</a>

                            <a href="/Admin/EditShelter/@shelter.Id" class="btn btn-sm btn-warning">Edit</a>

                            <form action="/Admin/DeleteShelter/@shelter.Id"
                                  method="post"
                                  style="display:inline"
                                  onsubmit="return confirm('Are you sure you want to delete this shelter?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>