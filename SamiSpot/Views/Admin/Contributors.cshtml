@model List<SamiSpot.Models.User>

<style>
    body {
        background: #f4fbfd;
    }

    .contributors-page {
        width: 100%;
        padding: 40px 60px;
        margin: 0;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 15px;
        margin-bottom: 30px;
    }

    .page-title {
        font-size: 38px;
        font-weight: 800;
        color: #2c4a52;
        margin: 0;
    }

    .page-subtitle {
        color: #5a7c84;
        font-size: 16px;
        margin-top: 5px;
    }

    .add-btn {
        background: #28a745;
        color: white;
        border-radius: 30px;
        padding: 12px 24px;
        font-weight: 800;
        text-decoration: none;
        box-shadow: 0 8px 18px rgba(40,167,69,0.25);
    }

        .add-btn:hover {
            background: #218838;
            color: white;
        }

    .table-wrapper {
        overflow-x: auto;
    }

    .custom-table {
        width: 100%;
        border-collapse: collapse;
    }

        .custom-table thead th {
            background: #eaf9fc;
            padding: 16px;
            font-weight: 800;
            color: #2c4a52;
            border-bottom: 2px solid #cdeff5;
        }

        .custom-table tbody tr {
            background: #ffffff;
            transition: 0.2s;
        }

            .custom-table tbody tr:hover {
                background: #f9feff;
                box-shadow: 0 6px 18px rgba(0,0,0,0.05);
            }

        .custom-table tbody td {
            padding: 18px 16px;
            color: #3c5c63;
            border-bottom: 1px solid #dceff3;
            vertical-align: middle;
        }

    .id-cell {
        font-weight: 800;
        color: #4bbfd3;
    }

    .status-active {
        color: #198754;
        font-weight: 800;
    }

    .status-inactive {
        color: #dc3545;
        font-weight: 800;
    }

    .action-btn {
        border-radius: 20px;
        padding: 6px 14px;
        font-weight: 700;
        margin-right: 5px;
    }

    .empty-box {
        background: #eaf9fc;
        border-left: 5px solid #4bbfd3;
        padding: 20px;
        border-radius: 10px;
        color: #2c4a52;
    }

    @@media (max-width: 768px) {
        .contributors-page {
            padding: 25px;
        }

        .custom-table {
            min-width: 800px;
        }
    }
</style>

<div class="contributors-page">

    <div class="page-header">
        <div>
            <h2 class="page-title">🛠️ All Contributors</h2>
            <p class="page-subtitle">Manage contributor accounts and permissions.</p>
        </div>

        <a asp-action="AddUser" asp-route-role="Contributor" class="add-btn">
            + Add Contributor
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-box">
            No contributors found.
        </div>
    }
    else
    {
        <div class="table-wrapper">
            <table class="custom-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>User Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td class="id-cell">@user.Id</td>
                            <td>@user.UserName</td>
                            <td>@user.Email</td>
                            <td>@user.RoleType</td>

                            <td>
                                @if (user.IsActive)
                                {
                                    <span class="status-active">Active</span>
                                }
                                else
                                {
                                    <span class="status-inactive">Inactive</span>
                                }
                            </td>

                            <td>
                                @if (user.IsActive)
                                {
                                    <form asp-action="DeactivateUser" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@user.Id" />
                                        <button type="submit" class="btn btn-warning btn-sm action-btn">
                                            Deactivate
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <form asp-action="ActivateUser" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@user.Id" />
                                        <button type="submit" class="btn btn-success btn-sm action-btn">
                                            Activate
                                        </button>
                                    </form>
                                }

                                <form asp-action="DeleteUser" method="post" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@user.Id" />
                                    <button type="submit" class="btn btn-danger btn-sm action-btn"
                                            onclick="return confirm('Are you sure you want to delete this user?');">
                                        Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

</div>