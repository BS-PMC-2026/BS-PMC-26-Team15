@{
    ViewData["Title"] = "Home";
}

<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

<style>
    .container {
        max-width: 100% !important;
        padding: 0 !important;
        margin: 0 !important;
    }

    body {
        background: #0d1117 !important;
        padding: 0 !important;
        margin: 0 !important;
    }

    /* kill the layout gap under navbar */
    header nav {
        border-bottom: none !important;
        box-shadow: none !important;
        margin-bottom: 0 !important;
    }

    :root {
        --brand: #e8622a;
        --brand-mid: #d4541e;
        --text-sub: rgba(255,255,255,0.75);
        --text-grey: #94a3b8;
        --navy: #0d1117;
    }

    /* ── HERO ── */
    .hero {
        position: relative;
        width: 100%;
        min-height: calc(100vh - 56px); /* full screen minus navbar */
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        overflow: hidden;
    }

    .hero-bg {
        position: absolute;
        inset: 0;
        background-image: url('https://images.unsplash.com/photo-1477959858617-67f85cf4f1df?w=1600&q=80');
        background-size: cover;
        background-position: center center;
        z-index: 0;
    }

    .hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient( to bottom, rgba(13,17,23,0.45) 0%, rgba(13,17,23,0.60) 50%, rgba(13,17,23,1.00) 100% );
        z-index: 1;
        pointer-events: none;
    }

    .hero-content {
        position: relative;
        z-index: 2;
        padding: 0 1.5rem;
        max-width: 680px;
        margin: 0 auto;
        margin-bottom: 5rem; /* push text up a bit from cards */
    }

    .hero-title {
        font-family: 'DM Sans', sans-serif;
        font-size: clamp(2.6rem, 5vw, 3.8rem);
        font-weight: 800;
        color: #fff;
        letter-spacing: -0.02em;
        line-height: 1.08;
        margin-bottom: 1rem;
        animation: fadeUp .55s ease both;
    }

    .hero-sub {
        font-family: 'DM Sans', sans-serif;
        font-size: 1.05rem;
        color: var(--text-sub);
        line-height: 1.75;
        margin-bottom: 2rem;
        animation: fadeUp .55s .12s ease both;
    }

    .hero-btn {
        display: inline-block;
        background: var(--brand);
        color: #fff;
        font-family: 'DM Sans', sans-serif;
        font-size: 0.97rem;
        font-weight: 700;
        padding: 13px 38px;
        border-radius: 50px;
        text-decoration: none;
        transition: background .18s, transform .14s, box-shadow .18s;
        box-shadow: 0 4px 20px rgba(232,98,42,.5);
        animation: fadeUp .55s .22s ease both;
    }

        .hero-btn:hover {
            background: var(--brand-mid);
            transform: translateY(-2px);
            box-shadow: 0 8px 28px rgba(232,98,42,.6);
            color: #fff;
            text-decoration: none;
        }

    /* ── CARDS — sit inside hero at bottom ── */
    .cards-wrap {
        position: relative;
        z-index: 2;
        width: 100%;
        padding: 0 2rem 3rem;
    }

    .cards-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.4rem;
        max-width: 1100px;
        margin: 0 auto;
    }

    .card {
        background: rgba(22, 28, 39, 0.85);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 16px;
        padding: 1.75rem;
        backdrop-filter: blur(6px);
        animation: fadeUp .5s ease both;
        transition: transform .2s, box-shadow .2s;
    }

        .card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 30px rgba(0,0,0,.4);
        }

        .card:nth-child(1) {
            animation-delay: .15s;
        }

        .card:nth-child(2) {
            animation-delay: .25s;
        }

        .card:nth-child(3) {
            animation-delay: .35s;
        }

    .card-icon {
        width: 46px;
        height: 46px;
        background: var(--brand);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1rem;
    }

        .card-icon svg {
            width: 22px;
            height: 22px;
            stroke: #fff;
            fill: none;
            stroke-width: 2;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

    .card-title {
        font-family: 'DM Sans', sans-serif;
        font-size: 1.02rem;
        font-weight: 700;
        color: #fff;
        margin-bottom: .45rem;
    }

    .card-desc {
        font-family: 'DM Sans', sans-serif;
        font-size: 0.87rem;
        color: var(--text-grey);
        line-height: 1.65;
        margin: 0;
    }

    /* navy below everything */
    .page-floor {
        background: var(--navy);
        height: 1px;
    }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(16px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@media (max-width: 768px) {
        .cards-grid {
            grid-template-columns: 1fr;
        }

        .hero {
            min-height: 100vh;
        }
    }
</style>

<div class="hero">
    <div class="hero-bg"></div>
    <div class="hero-overlay"></div>

    <!-- text -->
    <div class="hero-content">
        <h1 class="hero-title">Find Shelter. Stay Safe.</h1>
        <p class="hero-sub">
            Instant navigation to the nearest protected space during emergencies.
        </p>
        <a href="/Map/Index" class="hero-btn">Get Started</a>
    </div>

    <!-- cards inside hero so they sit on the dark fade -->
    <div class="cards-wrap">
        <div class="cards-grid">

            <div class="card">
                <div class="card-icon">
                    <svg viewBox="0 0 24 24">
                        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                        <polyline points="9 22 9 12 15 12 15 22" />
                    </svg>
                </div>
                <div class="card-title">Nearby Shelters</div>
                <p class="card-desc">Instantly locate the closest emergency shelters with real-time availability and distance tracking.</p>
            </div>

            <div class="card">
                <div class="card-icon">
                    <svg viewBox="0 0 24 24">
                        <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
                        <path d="M13.73 21a2 2 0 0 1-3.46 0" />
                    </svg>
                </div>
                <div class="card-title">Real-time Alerts</div>
                <p class="card-desc">Receive immediate notifications about emergency situations and shelter updates in your area.</p>
            </div>

            <div class="card">
                <div class="card-icon">
                    <svg viewBox="0 0 24 24">
                        <line x1="22" y1="2" x2="11" y2="13" />
                        <polygon points="22 2 15 22 11 13 2 9 22 2" />
                    </svg>
                </div>
                <div class="card-title">Safe Routes</div>
                <p class="card-desc">Get turn-by-turn navigation on the safest and fastest routes to reach protected areas.</p>
            </div>

        </div>
    </div>
</div>

<div class="page-floor"></div>