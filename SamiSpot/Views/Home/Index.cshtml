@{
    ViewData["Title"] = "Home";
}

<style>
    .container {
        max-width: 100% !important;
        padding: 0 !important;
        margin: 0 !important;
    }

    body {
        display: block !important;
        padding: 0 !important;
        background: #f8f9fa;
    }

    :root {
        --brand: #4bbfd3;
        --brand-mid: #35a8be;
        --brand-light: #89d8e8;
        --brand-pale: #d8f4f9;
        --alert: #e03b2b;
        --text-primary: #1a1a1a;
        --text-secondary: #6b7280;
        --bg-panel: #f0f8fa;
        --border: rgba(75,191,211,.18);
        --border-mid: rgba(75,191,211,.32);
    }

    .hero-wrapper {
        width: 100%;
        max-width: 100%;
        margin: 0 auto;
        padding: 3rem 2rem;
    }

    .hero-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 3rem;
        min-height: 650px;
    }

    .left,
    .right {
        flex: 1;
    }

    .right {
        display: flex;
        justify-content: flex-start;
        margin-left: -120px;
    }

    .hs-map {
        width: 100%;
        max-width: 900px;
        height: 620px;
    }

    .left {
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding-left: 1rem;
        padding-right: 0;
    }

    .hs-badge {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        font-family: 'DM Mono', monospace;
        font-size: 11px;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--brand-mid);
        border: 0.5px solid var(--border-mid);
        background: var(--brand-pale);
        padding: 5px 13px;
        border-radius: 100px;
        margin-bottom: 1.25rem;
    }

    .hs-badge-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--brand);
        animation: hsPulseDot 2s ease-in-out infinite;
    }

    .hs-title {
        font-size: 5.7rem;
        font-weight: 700;
        letter-spacing: -.04em;
        line-height: 1.02;
        letter-spacing: -.04em;
        line-height: 1.05;
        color: var(--text-primary);
        margin-bottom: 1rem;
        font-family: 'DM Sans', sans-serif;
    }

    .left {
        width: 43%;
        padding-left: 8rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

        .hs-title span {
            color: var(--brand);
        }

    .hs-sub {
        font-size: 1.25rem;
        line-height: 1.8;
        color: var(--text-secondary);
        max-width: 100%;
        margin-bottom: 1.75rem;
        font-family: 'DM Sans', sans-serif;
    }

    .hs-btn-group {
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
        margin-bottom: 2rem;
    }

    .hs-btn-primary {
        background: var(--brand);
        color: #fff;
        font-size: 14px;
        font-weight: 500;
        padding: 12px 26px;
        border-radius: 8px;
        border: none;
        cursor: pointer;
        text-decoration: none;
        display: inline-block;
        transition: background .18s, transform .12s;
        font-family: 'DM Sans', sans-serif;
    }

        .hs-btn-primary:hover {
            background: var(--brand-mid);
            transform: translateY(-1px);
            color: #fff;
            text-decoration: none;
        }

    .hs-btn-ghost {
        font-size: 14px;
        color: var(--text-secondary);
        background: none;
        border: 0.5px solid rgba(0,0,0,.15);
        padding: 12px 26px;
        border-radius: 8px;
        cursor: pointer;
        text-decoration: none;
        display: inline-block;
        transition: border-color .18s, color .18s;
        font-family: 'DM Sans', sans-serif;
    }

        .hs-btn-ghost:hover {
            color: var(--text-primary);
            border-color: var(--brand);
            text-decoration: none;
        }

    .hs-features {
        display: flex;
        gap: 1.5rem;
        flex-wrap: wrap;
    }

    .hs-feat {
        display: flex;
        align-items: center;
        gap: 7px;
        font-size: 13px;
        color: var(--text-secondary);
        font-family: 'DM Sans', sans-serif;
    }

        .hs-feat svg {
            width: 15px;
            height: 15px;
            stroke: var(--brand);
            fill: none;
            flex-shrink: 0;
        }

    .hs-map {
        position: relative;
        border-radius: 16px;
        background: var(--bg-panel);
        border: 1.5px solid var(--border-mid);
        height: 650px;
        overflow: hidden;
    }

    .hs-map-svg {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
    }

    .hs-ring {
        position: absolute;
        border-radius: 50%;
        border: 2px solid var(--brand);
        opacity: 0;
        animation: hsRadar 3s ease-out infinite;
        pointer-events: none;
    }

        .hs-ring:nth-child(1) {
            width: 100px;
            height: 100px;
            top: calc(48% - 50px);
            left: calc(42% - 50px);
            animation-delay: 0s;
        }

        .hs-ring:nth-child(2) {
            width: 180px;
            height: 180px;
            top: calc(48% - 90px);
            left: calc(42% - 90px);
            animation-delay: .5s;
        }

        .hs-ring:nth-child(3) {
            width: 280px;
            height: 280px;
            top: calc(48% - 140px);
            left: calc(42% - 140px);
            animation-delay: 1s;
        }

    .hs-dot {
        position: absolute;
        top: 48%;
        left: 42%;
        transform: translate(-50%, -50%);
        width: 18px;
        height: 18px;
        border-radius: 50%;
        background: var(--brand);
        z-index: 6;
        box-shadow: 0 0 0 5px rgba(75,191,211,.3), 0 2px 8px rgba(0,0,0,.2);
    }

        .hs-dot::after {
            content: '';
            position: absolute;
            inset: -6px;
            border-radius: 50%;
            border: 2.5px solid var(--brand);
            opacity: .35;
            animation: hsPulseDot 1.5s ease-in-out infinite;
        }

    .hs-lines {
        position: absolute;
        inset: 0;
        pointer-events: none;
        z-index: 3;
    }

    .hs-pin {
        position: absolute;
        display: flex;
        align-items: center;
        gap: 6px;
        border-radius: 9px;
        padding: 8px 13px;
        font-size: 12.5px;
        font-weight: 600;
        white-space: nowrap;
        z-index: 7;
        animation: hsPinIn .5s ease both;
        box-shadow: 0 3px 12px rgba(0,0,0,.15);
        font-family: 'DM Sans', sans-serif;
    }

        .hs-pin svg {
            width: 14px;
            height: 14px;
            fill: none;
            flex-shrink: 0;
        }

    .hs-pin-s1 {
        top: 16%;
        left: 52%;
        background: var(--brand);
        color: #fff;
        animation-delay: .3s;
    }

        .hs-pin-s1 svg {
            stroke: #fff;
        }

    .hs-pin-s2 {
        top: 60%;
        left: 62%;
        background: var(--brand);
        color: #fff;
        animation-delay: 1s;
    }

        .hs-pin-s2 svg {
            stroke: #fff;
        }

    .hs-pin-s3 {
        top: 28%;
        left: 14%;
        background: var(--brand);
        color: #fff;
        animation-delay: 1.4s;
    }

        .hs-pin-s3 svg {
            stroke: #fff;
        }

    .hs-pin-al {
        top: 70%;
        left: 24%;
        background: var(--alert);
        color: #fff;
        animation-delay: .7s;
    }

        .hs-pin-al svg {
            stroke: #fff;
        }

    .hs-alert-zone {
        position: absolute;
        top: 72%;
        left: 26%;
        width: 130px;
        height: 130px;
        border-radius: 50%;
        background: rgba(224,59,43,.1);
        border: 2px solid rgba(224,59,43,.28);
        transform: translate(-50%, -50%);
        z-index: 2;
        animation: hsAlertZone 3s ease-in-out infinite;
    }

    .hs-alert-pulse {
        position: absolute;
        top: 72%;
        left: 26%;
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: var(--alert);
        opacity: 0;
        transform: translate(-50%, -50%);
        animation: hsAlertWave 2.2s ease-out infinite;
        animation-delay: 1.2s;
        z-index: 2;
    }

    .hs-statusbar {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        display: flex;
        border-top: 1px solid var(--border-mid);
        background: rgba(255,255,255,.92);
    }

    .hs-stat {
        flex: 1;
        padding: 10px 14px;
        display: flex;
        align-items: center;
        gap: 7px;
        font-size: 12px;
        color: var(--text-secondary);
        border-right: 0.5px solid var(--border);
        font-family: 'DM Sans', sans-serif;
    }

        .hs-stat:last-child {
            border-right: none;
        }

        .hs-stat svg {
            width: 15px;
            height: 15px;
            fill: none;
            flex-shrink: 0;
        }

    .hs-stat-val {
        font-weight: 600;
        color: var(--text-primary);
        font-size: 13px;
    }

    .hs-stat-blue svg {
        stroke: var(--brand);
    }

    .hs-stat-red svg {
        stroke: var(--alert);
    }

    .hs-compass {
        position: absolute;
        top: 16px;
        right: 16px;
        width: 44px;
        height: 44px;
        background: rgba(255,255,255,.9);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 2px 8px rgba(0,0,0,.12);
        z-index: 8;
        font-size: 13px;
        font-weight: 700;
        color: #333;
        font-family: 'DM Sans', sans-serif;
    }

    .hs-zoom {
        position: absolute;
        top: 70px;
        right: 16px;
        display: flex;
        flex-direction: column;
        background: rgba(255,255,255,.9);
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0,0,0,.12);
        z-index: 8;
    }

    .hs-zoom-btn {
        width: 36px;
        height: 36px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        color: #555;
        cursor: pointer;
        border: none;
        background: none;
        border-bottom: 0.5px solid rgba(0,0,0,.1);
        transition: background .15s;
        line-height: 1;
    }

        .hs-zoom-btn:last-child {
            border-bottom: none;
        }

        .hs-zoom-btn:hover {
            background: rgba(75,191,211,.15);
            color: var(--brand);
        }

    .hs-scale {
        position: absolute;
        bottom: 50px;
        right: 20px;
        background: rgba(255,255,255,.88);
        border-radius: 6px;
        padding: 5px 10px;
        font-size: 11px;
        color: #555;
        font-family: 'DM Mono', monospace;
        z-index: 8;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .hs-badge {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        font-family: 'DM Mono', monospace;
        font-size: 11px;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--brand-mid);
        border: 0.5px solid var(--border-mid);
        background: var(--brand-pale);
        padding: 5px 13px;
        border-radius: 100px;
        margin-bottom: 1.25rem;
        width: fit-content; /* add this */
    }
    .hs-scale-bar {
        width: 50px;
        height: 3px;
        background: #555;
        border-radius: 2px;
    }

    .hs-fade {
        animation: hsFadeUp .6s ease both;
    }

        .hs-fade:nth-child(1) {
            animation-delay: 0s;
        }

        .hs-fade:nth-child(2) {
            animation-delay: .1s;
        }

        .hs-fade:nth-child(3) {
            animation-delay: .2s;
        }

        .hs-fade:nth-child(4) {
            animation-delay: .3s;
        }

        .hs-fade:nth-child(5) {
            animation-delay: .4s;
        }

        .hs-fade:nth-child(6) {
            animation-delay: .5s;
        }

    @@keyframes hsPulseDot {
        0% {
            opacity: 1;
            transform: scale(1);
        }

        50% {
            opacity: .4;
            transform: scale(.65);
        }

        100% {
            opacity: 1;
            transform: scale(1);
        }
    }

    @@keyframes hsRadar {
        0% {
            opacity: .6;
            transform: scale(.5);
        }

        100% {
            opacity: 0;
            transform: scale(1);
        }
    }

    @@keyframes hsPinIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes hsAlertWave {
        0% {
            opacity: .25;
            transform: translate(-50%, -50%) scale(.4);
        }

        100% {
            opacity: 0;
            transform: translate(-50%, -50%) scale(3);
        }
    }

    @@keyframes hsAlertZone {
        0%, 100% {
            transform: translate(-50%, -50%) scale(1);
            opacity: 1;
        }

        50% {
            transform: translate(-50%, -50%) scale(1.08);
            opacity: .7;
        }
    }

    @@keyframes hsFadeUp {
        from {
            opacity: 0;
            transform: translateY(14px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@media (max-width: 1024px) {
        .hero-wrapper {
            padding: 3rem 2rem;
        }

        .hero-inner {
            gap: 1.5rem;
            min-height: 500px;
        }

        .hs-title {
            font-size: 3.5rem;
        }

        .hs-map {
            height: 460px;
        }
    }

    @@media (max-width: 768px) {
        .hero-inner {
            grid-template-columns: 1fr;
            gap: 2rem;
        }

        .hs-title {
            font-size: 2.6rem;
        }

        .hs-map {
            height: 320px;
        }

        .left {
            padding-left: 0;
        }
    }
</style>

