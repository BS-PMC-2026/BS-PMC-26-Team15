@{
    ViewData["Title"] = "Map";
}
<link rel="stylesheet" href="~/css/map.css" />

<style>
    body {
        background: #0d1117;
        background-image: url('https://images.unsplash.com/photo-1477959858617-67f85cf4f1df?w=1600&auto=format&fit=crop&q=80');
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
        position: relative;
    }

        body::before {
            content: "";
            position: fixed;
            inset: 0;
            background: rgba(10, 15, 22, 0.72);
            z-index: 0;
            pointer-events: none;
        }

    .map-page {
        position: relative;
        z-index: 1;
        width: 100%;
        padding: 32px 48px;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    .map-title {
        font-size: 28px;
        font-weight: 800;
        color: #ffffff;
        margin-bottom: 4px;
    }

    .map-subtitle {
        color: #94b3bc;
        font-size: 14px;
        margin-bottom: 20px;
    }

    .map-toolbar {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
        margin-bottom: 20px;
    }

    /* Search bar — matches reference: border, icon inside, no button */
    .map-search-group {
        position: relative;
        min-width: 320px;
        flex: 1;
    }

    .map-search-icon {
        position: absolute;
        left: 14px;
        top: 50%;
        transform: translateY(-50%);
        color: rgba(255,255,255,0.4);
        pointer-events: none;
        display: flex;
        align-items: center;
    }

    .map-search-input {
        width: 100%;
        border-radius: 12px;
        border: 1.5px solid rgba(255,255,255,0.12);
        padding: 11px 16px 11px 40px;
        font-size: 14px;
        color: #ffffff;
        background: rgba(255,255,255,0.08);
        backdrop-filter: blur(8px);
        box-shadow: none;
        outline: none;
        transition: border-color 0.2s;
    }

        .map-search-input::placeholder {
            color: rgba(255,255,255,0.4);
        }

        .map-search-input:focus {
            border-color: #4bbfd3;
            background: rgba(255,255,255,0.12);
        }

    /* My Location dropdown */
    #myLocationDropdown {
        display: none;
        position: absolute;
        top: calc(100% + 4px);
        left: 0;
        right: 0;
        background: #1e2a32;
        border: 1.5px solid rgba(255,255,255,0.12);
        border-radius: 12px;
        box-shadow: 0 8px 24px rgba(0,0,0,0.4);
        z-index: 9999;
        overflow: hidden;
    }

        #myLocationDropdown .my-location-row {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 11px 16px;
            cursor: pointer;
            font-size: 14px;
            font-weight: 600;
            color: rgba(255,255,255,0.9);
            transition: background 0.15s;
        }

            #myLocationDropdown .my-location-row:hover {
                background: rgba(255,255,255,0.06);
            }

        #myLocationDropdown .my-location-icon {
            width: 28px;
            height: 28px;
            background: #e8f6f9;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

            #myLocationDropdown .my-location-icon svg {
                width: 14px;
                height: 14px;
                fill: #4bbfd3;
            }

    /* Walking / Driving toggle — two separate pill buttons like reference */
    .mode-toggle {
        display: flex;
        gap: 8px;
    }

    .mode-btn {
        display: flex;
        align-items: center;
        gap: 6px;
        border: 1.5px solid rgba(255,255,255,0.15);
        border-radius: 10px;
        padding: 9px 18px;
        font-weight: 600;
        font-size: 14px;
        cursor: pointer;
        background: rgba(255,255,255,0.08);
        backdrop-filter: blur(8px);
        color: rgba(255,255,255,0.6);
        transition: all 0.18s;
    }

        .mode-btn.active-walk {
            background: rgba(75,191,211,0.2);
            border-color: #4bbfd3;
            color: #7eeaf7;
        }

        .mode-btn.active-drive {
            background: rgba(245,158,11,0.2);
            border-color: #f59e0b;
            color: #fcd34d;
        }

    /* Closest Shelters button */
    #btnClosest {
        border: 1.5px solid rgba(255,255,255,0.15);
        border-radius: 10px;
        padding: 10px 20px;
        font-weight: 700;
        font-size: 14px;
        background: rgba(255,255,255,0.08);
        backdrop-filter: blur(8px);
        color: rgba(255,255,255,0.9);
        cursor: pointer;
        transition: all 0.2s;
    }

        #btnClosest:hover {
            background: rgba(255,255,255,0.15);
        }

    /* Layout */
    .map-layout {
        display: grid;
        grid-template-columns: 1fr 340px;
        gap: 18px;
    }

    .map-map-area {
        position: relative;
    }

    #map {
        width: 100%;
        height: 620px;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
    }

    /* Map legend — white card, clean */
    .map-legend {
        position: absolute;
        top: 16px;
        left: 16px;
        z-index: 10;
        background: white;
        border-radius: 16px;
        padding: 16px 18px;
        box-shadow: 0 4px 16px rgba(0,0,0,0.10);
        min-width: 170px;
    }

    .map-legend-title {
        font-weight: 700;
        font-size: 13px;
        color: #1a2e35;
        margin-bottom: 12px;
    }

    .map-legend-item {
        display: flex;
        align-items: center;
        gap: 9px;
        font-size: 13px;
        color: #4a6572;
        margin-bottom: 8px;
    }

    .legend-color {
        width: 13px;
        height: 13px;
        border-radius: 50%;
        display: inline-block;
        flex-shrink: 0;
    }

        .legend-color.red {
            background: #ef4444;
        }

        .legend-color.yellow {
            background: #f59e0b;
        }

    /* Shelter panel */
    .shelter-panel {
        background: rgba(18, 26, 32, 0.82);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 20px;
        padding: 24px;
        min-height: 620px;
        box-shadow: 0 8px 32px rgba(0,0,0,0.35);
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        color: rgba(255,255,255,0.9);
    }

        .shelter-panel h4 {
            color: #ffffff;
            font-weight: 800;
            font-size: 18px;
        }

        .shelter-panel p {
            color: rgba(255,255,255,0.5);
        }

    .stat-text-label {
        color: rgba(255,255,255,0.45) !important;
    }

    .stat-text-value {
        color: #ffffff !important;
    }

    .stat-row {
        border-bottom-color: rgba(255,255,255,0.07) !important;
    }

    /* Stat row — icon + label + value, like reference */
    .stat-row {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 14px 0;
        border-bottom: 1px solid #f1f5f9;
    }

        .stat-row:last-of-type {
            border-bottom: none;
        }

    .stat-icon {
        width: 38px;
        height: 38px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        font-size: 18px;
    }

    .stat-text-label {
        font-size: 12px;
        color: #6b8a93;
        margin-bottom: 2px;
    }

    .stat-text-value {
        font-size: 16px;
        font-weight: 700;
        color: #1a2e35;
    }

    /* Dark Google autocomplete dropdown */
    .pac-container {
        background: rgba(18, 26, 32, 0.96) !important;
        backdrop-filter: blur(12px) !important;
        border: 1px solid rgba(255,255,255,0.12) !important;
        border-radius: 12px !important;
        box-shadow: 0 8px 32px rgba(0,0,0,0.5) !important;
        margin-top: 4px !important;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif !important;
    }

    .pac-item {
        background: transparent !important;
        color: rgba(255,255,255,0.8) !important;
        border-top: 1px solid rgba(255,255,255,0.06) !important;
        padding: 10px 14px !important;
        cursor: pointer !important;
        font-size: 13px !important;
    }

        .pac-item:hover, .pac-item-selected {
            background: rgba(255,255,255,0.07) !important;
        }

    .pac-item-query {
        color: #ffffff !important;
        font-weight: 600 !important;
    }

    .pac-icon {
        filter: invert(1) opacity(0.4) !important;
    }

    .pac-matched {
        color: #4bbfd3 !important;
    }

    .pac-logo::after {
        display: none !important;
    }

    @@media (max-width: 1100px) {
        .map-layout {
            grid-template-columns: 1fr;
        }

        .shelter-panel {
            min-height: auto;
        }
    }
</style>

<div class="map-page">

    <h2 class="map-title">Safety Map</h2>
    <p class="map-subtitle">Find nearby shelters and choose the safest route</p>

    <div class="map-toolbar">
        <!-- Search bar with icon inside -->
        <div class="map-search-group">
            <span class="map-search-icon">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z" />
                    <circle cx="12" cy="10" r="3" />
                </svg>
            </span>
            <input id="searchBox" type="text" class="map-search-input"
                   placeholder="123 Main Street, Downtown" autocomplete="off" />

            <div id="myLocationDropdown">
                <div class="my-location-row" id="myLocationRow">
                    <div class="my-location-icon">
                        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" />
                        </svg>
                    </div>
                    My Location
                </div>
            </div>
        </div>

        <!-- Two separate pill buttons like reference -->
        <div class="mode-toggle">
            <button id="btnWalking" class="mode-btn active-walk" onclick="setTravelMode('WALKING')">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="5" r="2" />
                    <path d="M12 7v6l-3 3M9 13l3-3 3 3M12 19v-3" />
                </svg>
                Walking
            </button>
            <button id="btnDriving" class="mode-btn" onclick="setTravelMode('DRIVING')">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="1" y="9" width="22" height="9" rx="2" />
                    <path d="M5 9V7a4 4 0 0 1 4-4h6a4 4 0 0 1 4 4v2" />
                    <circle cx="7" cy="18" r="1" />
                    <circle cx="17" cy="18" r="1" />
                </svg>
                Driving
            </button>
        </div>
        <input type="hidden" id="travelMode" value="WALKING" />

        <button id="btnClosest">Closest Shelters</button>
    </div>

    <div class="map-layout">
        <div class="map-map-area">
            <div class="map-legend">
                <div class="map-legend-title">Map Legend</div>

                <div class="map-legend-item">
                    <span class="legend-color red"></span>
                    Real-time alert
                </div>

                <div class="map-legend-item">
                    <span class="legend-color yellow"></span>
                    Alert in last 24 hours
                </div>

                <div class="map-legend-item">
                    <img src="https://maps.google.com/mapfiles/ms/icons/red-dot.png" style="width:14px;height:14px;" />
                    Official Shelter
                </div>

                <div class="map-legend-item">
                    <img src="https://maps.google.com/mapfiles/ms/icons/green-dot.png" style="width:14px;height:14px;" />
                    Contributor Shelter
                </div>
            </div>

            <div id="map"></div>
        </div>

        <div id="shelterPanel" class="shelter-panel">
            <h4>Shelter Details</h4>
            <p style="color:#6b8a93;font-size:14px;margin-top:6px;">Click a shelter on the map to view details.</p>
        </div>
    </div>
</div>

<script>
    const loggedInUser = '@Context.Session.GetString("UserName")';
</script>

<script>
    let map;
    let userMarker;
    let autocomplete;
    let geocoder;
    let infoWindow;
    let shelterMarkers = [];
    let riskCircles = {};
    let userLocation = null;

    let closestListData = [];
    let closestShelterMarkers = [];
    let allShelters = [];

    let directionsService;
    let directionsRenderer;
    let selectedShelterIndex = null;

    function isUserLoggedIn() {
        return loggedInUser && loggedInUser !== '';
    }

    function initMap() {
        const defaultCenter = { lat: 31.2518, lng: 34.7913 };

        map = new google.maps.Map(document.getElementById("map"), {
            center: defaultCenter,
            zoom: 8,
            mapTypeControl: false,
            streetViewControl: false,
            fullscreenControl: false
        });

        geocoder = new google.maps.Geocoder();
        infoWindow = new google.maps.InfoWindow();

        directionsService = new google.maps.DirectionsService();
        directionsRenderer = new google.maps.DirectionsRenderer({
            suppressMarkers: true,
            preserveViewport: true,
            polylineOptions: {
                strokeColor: "#000000",
                strokeOpacity: 1.0,
                strokeWeight: 7
            }
        });
        directionsRenderer.setMap(map);

        userMarker = new google.maps.Marker({
            position: defaultCenter,
            map: map,
            icon: "https://maps.google.com/mapfiles/ms/icons/blue-dot.png",
            title: "Your location"
        });

        const input = document.getElementById("searchBox");
        const dropdown = document.getElementById("myLocationDropdown");
        const myLocationRow = document.getElementById("myLocationRow");

        // Show "My Location" option immediately when the user focuses the search bar
        input.addEventListener("focus", function () {
            dropdown.style.display = "block";
        });

        // Hide "My Location" row once user starts typing (Google autocomplete takes over)
        input.addEventListener("input", function () {
            if (input.value.trim() !== "") {
                dropdown.style.display = "none";
            } else {
                dropdown.style.display = "block";
            }
        });

        // Hide when clicking anywhere outside the search group
        document.addEventListener("click", function (e) {
            if (!document.querySelector(".map-search-group").contains(e.target)) {
                dropdown.style.display = "none";
            }
        });

        // Handle "My Location" selection — mousedown so it fires before blur hides the dropdown
        myLocationRow.addEventListener("mousedown", function (e) {
            e.preventDefault();
            dropdown.style.display = "none";
            input.value = "My Location";
            navigator.geolocation.getCurrentPosition(
                pos => {
                    moveToLocation(
                        { lat: pos.coords.latitude, lng: pos.coords.longitude },
                        "You are here"
                    );
                },
                () => alert("Cannot get location.")
            );
        });

        autocomplete = new google.maps.places.Autocomplete(input);
        autocomplete.addListener("place_changed", function () {
            const place = autocomplete.getPlace();
            if (!place.geometry) return;
            dropdown.style.display = "none";
            moveToLocation(place.geometry.location, "Selected location");
        });

        input.addEventListener("keydown", function (e) {
            if (e.key === "Enter") {
                e.preventDefault();
                const address = input.value.trim();
                if (!address || address === "My Location") return;
                geocoder.geocode({ address }, (res, status) => {
                    if (status === "OK") {
                        dropdown.style.display = "none";
                        moveToLocation(res[0].geometry.location, "Selected location");
                    } else {
                        alert("Location not found");
                    }
                });
            }
        });

        document.getElementById("btnClosest").onclick = loadClosestShelters;

        // travelMode is now controlled by toggle buttons via setTravelMode()

        loadShelters();
        loadCityRisks();
        setInterval(loadCityRisks, 5000);
    }

    function moveToLocation(location, title) {
        map.setCenter(location);
        map.setZoom(12);
        userMarker.setPosition(location);
        userMarker.setTitle(title);

        userLocation = {
            lat: typeof location.lat === "function" ? location.lat() : location.lat,
            lng: typeof location.lng === "function" ? location.lng() : location.lng
        };

        selectedShelterIndex = null;
        directionsRenderer.setDirections({ routes: [] });

        infoWindow.setContent(`<strong>${title}</strong>`);
        infoWindow.open(map, userMarker);
    }

    function getShelterFeedbackId(shelter) {
        if (shelter.source === "Contributor") {
            return 1000000000 + shelter.id;
        }
        return shelter.id;
    }

    function normalizeGovShelter(shelter) {
        return {
            id: shelter.id,
            name: shelter.name || "Unnamed Shelter",
            latitude: shelter.latitude,
            longitude: shelter.longitude,
            address: shelter.address || null,
            description: shelter.description || null,
            size: shelter.size ?? null,
            isAvailable: shelter.isAvailable ?? null,
            source: "Gov",
            images: []
        };
    }

    function normalizeContributorShelter(shelter) {
        return {
            id: shelter.id,
            name: shelter.name || "Unnamed Shelter",
            latitude: shelter.latitude,
            longitude: shelter.longitude,
            address: shelter.address || null,
            description: shelter.description || null,
            size: shelter.size ?? null,
            isAvailable: shelter.isAvailable ?? null,
            source: "Contributor",
            images: []
        };
    }

    async function loadShelters() {
        shelterMarkers.forEach(m => m.setMap(null));
        shelterMarkers = [];
        allShelters = [];

        let govShelters = [];
        let contributorShelters = [];

        try {
            const govResponse = await fetch('/api/shelters');
            if (govResponse.ok) {
                govShelters = await govResponse.json();
            }
        } catch (e) {
            console.error("failed loading gov shelters", e);
        }

        try {
            const contributorResponse = await fetch('/api/contributor-shelters');
            if (contributorResponse.ok) {
                contributorShelters = await contributorResponse.json();
            }
        } catch (e) {
            console.error("failed loading contributor shelters", e);
        }

        const normalizedGov = govShelters.map(normalizeGovShelter);
        const normalizedContributor = contributorShelters.map(normalizeContributorShelter);

        allShelters = [...normalizedGov, ...normalizedContributor];

        allShelters.forEach(shelter => {
            const marker = new google.maps.Marker({
                position: { lat: shelter.latitude, lng: shelter.longitude },
                map: map,
                icon: {
                    url: shelter.source === "Contributor"
                        ? "https://maps.google.com/mapfiles/ms/icons/green-dot.png"
                        : "https://maps.google.com/mapfiles/ms/icons/red-dot.png",
                    scaledSize: new google.maps.Size(20, 20)
                },
                title: shelter.name
            });

            marker.shelterId = shelter.id;
            marker.shelterSource = shelter.source;

            marker.addListener("click", async () => {
                await showShelterDetails(shelter);
            });

            shelterMarkers.push(marker);
        });

        const params = new URLSearchParams(window.location.search);
        const shelterId = params.get("shelterId");

        if (shelterId) {
            focusShelterById(parseInt(shelterId));
        }
    }

    async function showShelterDetails(shelter) {
        // Normalize lat/lng field names — markers use latitude/longitude
        const shelterForRoute = {
            id: shelter.id,
            name: shelter.name,
            lat: shelter.latitude,
            lng: shelter.longitude,
            source: shelter.source,
            isAvailable: shelter.isAvailable,
            size: shelter.size,
            feedbackId: getShelterFeedbackId(shelter)
        };

        if (userLocation) {
            // We have a location — calculate route and show name + distance + time
            const travelModeValue = document.getElementById("travelMode").value;
            directionsService.route(
                {
                    origin: userLocation,
                    destination: { lat: shelterForRoute.lat, lng: shelterForRoute.lng },
                    travelMode: google.maps.TravelMode[travelModeValue],
                    drivingOptions: travelModeValue === "DRIVING" ? {
                        departureTime: new Date(),
                        trafficModel: "bestguess"
                    } : undefined
                },
                (result, status) => {
                    if (status === "OK") {
                        const isWalking = travelModeValue === "WALKING";
                        directionsRenderer.setOptions({
                            polylineOptions: isWalking ? {
                                strokeColor: "#4bbfd3",
                                strokeOpacity: 0.0,
                                strokeWeight: 6,
                                icons: [{ icon: { path: "M 0,-1 0,1", strokeOpacity: 1, scale: 4 }, offset: "0", repeat: "16px" }]
                            } : {
                                strokeColor: "#f59e0b",
                                strokeOpacity: 1.0,
                                strokeWeight: 7,
                                icons: []
                            }
                        });
                        directionsRenderer.setDirections(result);
                        showRouteDetails(result, shelterForRoute, travelModeValue);
                    } else {
                        // Route failed — fall back to name only
                        showNameOnly(shelterForRoute);
                    }
                }
            );
        } else {
            // No location set — just show name and prompt
            showNameOnly(shelterForRoute);
        }
    }

    function showNameOnly(shelter) {
        let html = `
            <div style="margin-bottom:18px;">
                <div style="font-size:18px;font-weight:800;color:#2c4a52;margin-bottom:8px;line-height:1.3;">
                    ${shelter.name}
                </div>
            </div>
            <div style="
                background:#f8fdff;
                border:1px solid #d6f2f7;
                border-radius:16px;
                padding:18px;
                text-align:center;
                color:#5a7c84;
                font-size:13px;
                margin-bottom:20px;
            ">
                Set your location to see distance and travel time.
            </div>
        `;

        html += getFeedbackSection(shelter.feedbackId);

        document.getElementById("shelterPanel").innerHTML = html;
        loadFeedback(shelter.feedbackId);
    }

    async function loadClosestShelters() {
        if (!userLocation) {
            alert("Please choose a location first.");
            return;
        }

        const count = 10;

        if (!allShelters.length) {
            alert("No shelters loaded yet.");
            return;
        }

        const userLatLng = new google.maps.LatLng(userLocation.lat, userLocation.lng);

        const sorted = allShelters
            .map(s => {
                const shelterLatLng = new google.maps.LatLng(s.latitude, s.longitude);
                const distance = google.maps.geometry.spherical.computeDistanceBetween(userLatLng, shelterLatLng);
                return {
                    id: s.id,
                    feedbackId: getShelterFeedbackId(s),
                    name: s.name,
                    lat: s.latitude,
                    lng: s.longitude,
                    address: s.address,
                    description: s.description,
                    size: s.size,
                    isAvailable: s.isAvailable,
                    source: s.source,
                    images: s.images || [],
                    distance: distance
                };
            })
            .sort((a, b) => a.distance - b.distance)
            .slice(0, count);

        closestListData = sorted;
        renderClosestList(sorted);
    }

    function renderClosestList(list) {
        const panel = document.getElementById("shelterPanel");

        closestShelterMarkers.forEach(m => m.setMap(null));
        closestShelterMarkers = [];

        let html = `
            <div style="margin-bottom:20px;">
                <div style="font-size:22px;font-weight:900;color:#ffffff;margin-bottom:4px;letter-spacing:-0.3px;">
                    Closest ${list.length} Shelters
                </div>
                <div style="color:rgba(255,255,255,0.45);font-size:13px;">Tap a shelter to get directions</div>
            </div>
            <div style="display:flex;flex-direction:column;gap:10px;">
        `;

        list.forEach((s, i) => {
            let d = s.distance < 1000
                ? `${Math.round(s.distance)} m`
                : `${(s.distance / 1000).toFixed(2)} km`;

            const badgeColor = s.source === "Contributor" ? "#16a34a" : "#2c4a52";
            const badgeLabel = s.source === "Contributor" ? "Contributor" : "Official";

            const marker = new google.maps.Marker({
                position: { lat: s.lat, lng: s.lng },
                map: map,
                icon: {
                    url: "https://maps.google.com/mapfiles/ms/icons/purple-dot.png",
                    scaledSize: new google.maps.Size(20, 20)
                },
                zIndex: 9999,
                title: s.name
            });

            closestShelterMarkers.push(marker);

            marker.addListener("click", () => {
                focusClosest(i);
            });

            html += `
                <div onclick="focusClosest(${i})"
                    style="
                        background:#f8fdff;
                        border:1px solid #d6f2f7;
                        border-radius:16px;
                        padding:14px 16px;
                        cursor:pointer;
                        display:flex;
                        align-items:center;
                        justify-content:space-between;
                        gap:12px;
                    "
                    onmouseover="this.style.boxShadow='0 4px 16px rgba(75,191,211,0.2)';this.style.borderColor='#4bbfd3';"
                    onmouseout="this.style.boxShadow='none';this.style.borderColor='#d6f2f7';"
                >
                    <div style="display:flex;align-items:center;gap:12px;min-width:0;">
                        <div style="
                            width:34px;height:34px;
                            background:#e0f7fa;
                            border-radius:50%;
                            display:flex;align-items:center;justify-content:center;
                            flex-shrink:0;
                            font-size:14px;
                            color:#2c4a52;
                            font-weight:800;
                        ">${i + 1}</div>
                        <div style="min-width:0;">
                            <div style="font-weight:700;color:#2c4a52;font-size:14px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                                ${s.name}
                            </div>
                            <div style="margin-top:4px;">
                                <span style="
                                    background:${badgeColor};
                                    color:white;
                                    font-size:11px;
                                    font-weight:700;
                                    padding:2px 8px;
                                    border-radius:20px;
                                ">${badgeLabel}</span>
                            </div>
                        </div>
                    </div>
                    <div style="
                        flex-shrink:0;
                        background:#2c4a52;
                        color:white;
                        font-size:13px;
                        font-weight:800;
                        padding:6px 12px;
                        border-radius:20px;
                        white-space:nowrap;
                    ">${d}</div>
                </div>
            `;
        });

        html += "</div>";
        panel.innerHTML = html;
    }

    function focusClosest(i) {
        const s = closestListData[i];
        selectedShelterIndex = i;

        const shelterPos = { lat: s.lat, lng: s.lng };

        map.setCenter(shelterPos);
        map.setZoom(15);

        infoWindow.setContent(`<strong>${s.name}</strong>`);
        infoWindow.setPosition(shelterPos);
        infoWindow.open(map);

        drawRealRouteToShelter(s);
    }

    function setTravelMode(mode) {
        document.getElementById("travelMode").value = mode;

        const walkBtn = document.getElementById("btnWalking");
        const driveBtn = document.getElementById("btnDriving");

        walkBtn.className = "mode-btn" + (mode === "WALKING" ? " active-walk" : "");
        driveBtn.className = "mode-btn" + (mode === "DRIVING" ? " active-drive" : "");

        if (selectedShelterIndex !== null) {
            const s = closestListData[selectedShelterIndex];
            drawRealRouteToShelter(s);
        }
    }

    function drawRealRouteToShelter(shelter) {
        if (!userLocation) {
            alert("Please choose a location first.");
            return;
        }

        const travelModeValue = document.getElementById("travelMode").value;

        // Walking = blue dashed, Driving = amber solid
        const isWalking = travelModeValue === "WALKING";
        directionsRenderer.setOptions({
            polylineOptions: {
                strokeColor: isWalking ? "#4bbfd3" : "#f59e0b",
                strokeOpacity: isWalking ? 0 : 1.0,
                strokeWeight: 6
            }
        });

        directionsService.route(
            {
                origin: userLocation,
                destination: { lat: shelter.lat, lng: shelter.lng },
                travelMode: google.maps.TravelMode[travelModeValue],
                drivingOptions: travelModeValue === "DRIVING" ? {
                    departureTime: new Date(),
                    trafficModel: "bestguess"
                } : undefined
            },
            (result, status) => {
                if (status !== "OK") {
                    console.error("Directions failed:", status);
                    alert("Could not calculate route.");
                    return;
                }

                // For walking: draw a dashed blue line manually on top
                if (isWalking) {
                    directionsRenderer.setOptions({
                        polylineOptions: {
                            strokeColor: "#4bbfd3",
                            strokeOpacity: 0.0,
                            strokeWeight: 6,
                            icons: [{
                                icon: {
                                    path: "M 0,-1 0,1",
                                    strokeOpacity: 1,
                                    scale: 4
                                },
                                offset: "0",
                                repeat: "16px"
                            }]
                        }
                    });
                } else {
                    directionsRenderer.setOptions({
                        polylineOptions: {
                            strokeColor: "#f59e0b",
                            strokeOpacity: 1.0,
                            strokeWeight: 7,
                            icons: []
                        }
                    });
                }

                directionsRenderer.setDirections(result);
                showRouteDetails(result, shelter, travelModeValue);
            }
        );
    }

    function showRouteDetails(result, shelter, travelModeValue) {
        const route = result.routes[0];
        const leg = route.legs[0];

        const routeDistanceText = leg.distance ? leg.distance.text : "N/A";
        const routeDurationText = travelModeValue === "DRIVING"
            ? (leg.duration_in_traffic ? leg.duration_in_traffic.text : leg.duration ? leg.duration.text : "N/A")
            : (leg.duration ? leg.duration.text : "N/A");

        const isWalking = travelModeValue === "WALKING";
        const modeLabel = isWalking ? "Walking Route" : "Driving Route";
        const modeBadgeBg = isWalking ? "#e0faf5" : "#fff8e7";
        const modeBadgeColor = isWalking ? "#0e7490" : "#b45309";
        const timeIconBg = isWalking ? "#e8fafb" : "#fff8e7";
        const timeIconColor = isWalking ? "#4bbfd3" : "#f59e0b";

        const feedbackId = shelter.feedbackId || shelter.id;

        const available = shelter.isAvailable;
        const statusText = available === null || available === undefined ? null
                         : available ? "Available" : "Unavailable";
        const statusColor = available ? "#16a34a" : "#dc2626";
        const statusBg = available ? "#f0fdf4" : "#fef2f2";

        const capacityText = (shelter.size !== null && shelter.size !== undefined)
            ? shelter.size + " people" : null;

        const dest = encodeURIComponent(shelter.name);
        const modeParam = isWalking ? "walking" : "driving";
        const navUrl = `https://www.google.com/maps/dir/?api=1&destination=${dest}&travelmode=${modeParam}`;

        let html = `
            <div style="margin-bottom:20px;">
                <div style="font-size:20px;font-weight:800;color:#1a2e35;margin-bottom:10px;line-height:1.3;">
                    ${shelter.name}
                </div>
                <span style="background:${modeBadgeBg};color:${modeBadgeColor};font-size:12px;font-weight:700;padding:4px 12px;border-radius:20px;">
                    ${modeLabel}
                </span>
            </div>

            <div style="margin-bottom:12px;">

                <div class="stat-row">
                    <div class="stat-icon" style="background:#eef2ff;">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#6366f1" stroke-width="2">
                            <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
                        </svg>
                    </div>
                    <div>
                        <div class="stat-text-label">Distance</div>
                        <div class="stat-text-value">${routeDistanceText}</div>
                    </div>
                </div>

                <div class="stat-row">
                    <div class="stat-icon" style="background:${timeIconBg};">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="${timeIconColor}" stroke-width="2">
                            <circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>
                        </svg>
                    </div>
                    <div>
                        <div class="stat-text-label">Estimated Time</div>
                        <div class="stat-text-value">${routeDurationText}</div>
                    </div>
                </div>

                ${statusText ? `
                <div class="stat-row">
                    <div class="stat-icon" style="background:${statusBg};">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="${statusColor}" stroke-width="2">
                            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                            <polyline points="22 4 12 14.01 9 11.01"/>
                        </svg>
                    </div>
                    <div>
                        <div class="stat-text-label">Status</div>
                        <div class="stat-text-value" style="color:${statusColor};">${statusText}</div>
                    </div>
                </div>` : ""}

                ${capacityText ? `
                <div class="stat-row">
                    <div class="stat-icon" style="background:#f5f0ff;">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#9333ea" stroke-width="2">
                            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                            <circle cx="9" cy="7" r="4"/>
                            <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                            <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                        </svg>
                    </div>
                    <div>
                        <div class="stat-text-label">Capacity</div>
                        <div class="stat-text-value">${capacityText}</div>
                    </div>
                </div>` : ""}

            </div>

            <div style="margin-top:20px;">
        `;

        html += getFeedbackSection(feedbackId) + `</div>`;

        document.getElementById("shelterPanel").innerHTML = html;
        loadFeedback(feedbackId);
    }

    async function loadCityRisks() {
        const response = await fetch('/Map/GetCityRisks');
        const cities = await response.json();

        cities.forEach(city => {
            if (!city.latitude || !city.longitude) return;

            if (city.color === "green") {
                if (riskCircles[city.cityName]) {
                    riskCircles[city.cityName].setMap(null);
                    delete riskCircles[city.cityName];
                }
                return;
            }

            let color = city.color === "orange" ? "#FFA500" : city.color;

            if (!riskCircles[city.cityName]) {
                riskCircles[city.cityName] = new google.maps.Circle({
                    strokeColor: color,
                    fillColor: color,
                    strokeOpacity: 0.5,
                    fillOpacity: 0.18,
                    map: map,
                    center: { lat: city.latitude, lng: city.longitude },
                    radius: 2500
                });
            } else {
                riskCircles[city.cityName].setOptions({
                    strokeColor: color,
                    fillColor: color
                });
            }
        });
    }

    function getFeedbackSection(shelterId) {
        let inputPart = "";

        if (isUserLoggedIn()) {
            inputPart =
                '<textarea id="feedbackInput" class="form-control mt-2" placeholder="Write your feedback..."></textarea>' +
                '<button onclick="sendFeedback(' + shelterId + ')" class="btn btn-primary mt-2">Send</button>';
        } else {
            inputPart =
                '<p style="color:gray;">You must be logged in to write feedback.</p>' +
                '<a href="/Account/Login?returnUrl=/Map/Index?shelterId=' + shelterId + '" class="btn btn-outline-primary btn-sm">Login</a>' +
                '<a href="/Account/Register?returnUrl=/Map/Index?shelterId=' + shelterId + '" class="btn btn-outline-secondary btn-sm">Sign Up</a>';
        }

        return '<hr/>' +
               '<h5>Feedback</h5>' +
               '<div id="feedbackList">Loading feedback...</div>' +
               inputPart;
    }

    function getRoleBadge(role) {
        if (!role) return "";

        role = role.toLowerCase();

        if (role === "admin") {
            return '<span style="color:white;background:red;padding:2px 6px;border-radius:5px;font-size:12px;margin-left:5px;">Admin</span>';
        }

        if (role === "contributor") {
            return '<span style="color:white;background:green;padding:2px 6px;border-radius:5px;font-size:12px;margin-left:5px;">Contributor</span>';
        }

        return '<span style="color:white;background:blue;padding:2px 6px;border-radius:5px;font-size:12px;margin-left:5px;">User</span>';
    }

    async function loadFeedback(shelterId) {
        try {
            const res = await fetch(`/Feedback/GetByShelter?shelterId=${shelterId}`);

            if (!res.ok) {
                throw new Error("failed to load feedback");
            }

            const feedbacks = await res.json();
            let html = "";

            if (feedbacks.length === 0) {
                html = "<p>No feedback yet</p>";
            } else {
                for (const f of feedbacks) {
                    const repliesRes = await fetch(`/Feedback/GetReplies?feedbackId=${f.id}`);

                    if (!repliesRes.ok) {
                        throw new Error("failed to load replies");
                    }

                    const replies = await repliesRes.json();
                    let repliesHtml = "";

                    replies
                        .filter(r => r.parentReplyId === null)
                        .forEach(r => {
                            repliesHtml += renderReply(r, replies, f.id, shelterId, 0);
                        });

                    html += `
                        <div style="border-bottom:1px solid #ccc; margin-bottom:10px; padding-bottom:10px;">
                            <strong>${f.userName}</strong> ${getRoleBadge(f.role)}
                            <small style="color:gray;"> (${new Date(f.createdAt).toLocaleString()})</small>
                            <p>${f.comment}</p>

                            ${isUserLoggedIn() ? `
                                <button onclick="showReplyBox(${f.id})" class="btn btn-sm btn-outline-secondary">
                                    Reply
                                </button>

                                <div id="replyBox-${f.id}" style="display:none; margin-top:5px;">
                                    <textarea id="replyInput-${f.id}" class="form-control" placeholder="Write reply..."></textarea>
                                    <button onclick="sendReply(${f.id}, ${shelterId})" class="btn btn-sm btn-success mt-1">
                                        Send Reply
                                    </button>
                                </div>
                            ` : `
                                <p style="color:gray;">You must be logged in to reply.</p>
                            `}

                            <div style="margin-top:10px;">
                                ${repliesHtml}
                            </div>
                        </div>
                    `;
                }
            }

            document.getElementById("feedbackList").innerHTML = html;
        } catch (err) {
            console.error("loadFeedback error:", err);
            document.getElementById("feedbackList").innerHTML = "Error loading feedback ^-^";
        }
    }

    function showReplyBox(feedbackId) {
        const box = document.getElementById(`replyBox-${feedbackId}`);
        if (box) {
            box.style.display = "block";
        }
    }

    function showNestedReplyBox(replyId) {
        const box = document.getElementById(`replyBox-reply-${replyId}`);
        if (box) {
            box.style.display = "block";
        }
    }

    function renderReply(reply, allReplies, feedbackId, shelterId, level) {
        const children = allReplies.filter(r => r.parentReplyId === reply.id);

        let childrenHtml = "";
        children.forEach(child => {
            childrenHtml += renderReply(child, allReplies, feedbackId, shelterId, level + 1);
        });

        return `
            <div style="margin-left:${level * 20}px; border-left:2px solid #ddd; padding-left:10px; margin-top:8px;">
                <strong>${reply.userName}</strong> ${getRoleBadge(reply.role)}
                <small style="color:gray;"> (${new Date(reply.createdAt).toLocaleString()})</small>
                <p>${reply.replyText}</p>

                ${isUserLoggedIn() ? `
                    <button onclick="showNestedReplyBox(${reply.id})" class="btn btn-sm btn-outline-secondary">
                        Reply
                    </button>

                    <div id="replyBox-reply-${reply.id}" style="display:none; margin-top:5px;">
                        <textarea id="replyInput-reply-${reply.id}" class="form-control" placeholder="Write reply..."></textarea>
                        <button onclick="sendReply(${feedbackId}, ${shelterId}, ${reply.id})" class="btn btn-sm btn-success mt-1">
                            Send Reply
                        </button>
                    </div>
                ` : `
                    <p style="color:gray;">You must be logged in to reply.</p>
                `}

                ${childrenHtml}
            </div>
        `;
    }

    async function sendReply(feedbackId, shelterId, parentReplyId = null) {
        const inputId = parentReplyId ? `replyInput-reply-${parentReplyId}` : `replyInput-${feedbackId}`;
        const input = document.getElementById(inputId);

        if (!input) {
            alert("Reply box not found.");
            return;
        }

        const text = input.value.trim();

        if (!text) {
            alert("Write a reply first!");
            return;
        }

        try {
            const response = await fetch("/Feedback/AddReply", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                    feedbackId: feedbackId,
                    parentReplyId: parentReplyId,
                    replyText: text
                })
            });

            const result = await response.json().catch(() => null);

            if (response.status === 401) {
                alert("You must log in to reply.");
                return;
            }

            if (!response.ok) {
                alert(result?.message || "Failed to save reply.");
                return;
            }

            input.value = "";
            await loadFeedback(shelterId);
        } catch (err) {
            console.error("sendReply error:", err);
            alert("Error while sending reply.");
        }
    }

    async function sendFeedback(shelterId) {
        const input = document.getElementById("feedbackInput");
        const text = input.value.trim();

        if (!text) {
            alert("Write something first!");
            return;
        }

        try {
            const response = await fetch("/Feedback/Add", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                    shelterId: shelterId,
                    comment: text
                })
            });

            const result = await response.json().catch(() => null);

            if (response.status === 401) {
                alert("You must log in to write feedback.");
                return;
            }

            if (!response.ok) {
                alert(result?.message || "Failed to save feedback.");
                return;
            }

            input.value = "";
            await loadFeedback(shelterId);
        } catch (err) {
            console.error("sendFeedback error:", err);
            alert("Error while sending feedback.");
        }
    }

    function focusShelterById(id) {
        const marker = shelterMarkers.find(m => m.shelterId === id);

        if (marker) {
            google.maps.event.trigger(marker, "click");
        } else {
            console.log("Marker not found for id:", id);
        }
    }

    window.initMap = initMap;
</script>

<script async defer
        src="https://maps.googleapis.com/maps/api/js?key=AIzaSyAuiZcDNCGOmwM7OSjNncN7yrjIjcRMzJk&libraries=places,geometry&callback=initMap">
</script>