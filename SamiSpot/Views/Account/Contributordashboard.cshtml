@{
    ViewData["Title"] = "Contributor Dashboard";
}

<style>
    body {
        background: #f4fbfd;
    }

    .dashboard-header {
        text-align: center;
        margin-top: 25px;
        margin-bottom: 10px;
    }

    .dashboard-title {
        font-size: 32px;
        font-weight: 700;
        color: #2c4a52;
    }

    .dashboard-sub {
        color: #5a7c84;
        margin-top: 5px;
    }

    .dashboard-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 24px;
        padding: 40px;
    }

    .dash-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 160px;
        background: linear-gradient(135deg, #ffffff, #f0fcf6);
        border-radius: 22px;
        border: 1px solid #d9f3e3;
        text-decoration: none;
        color: #2c4a52;
        font-size: 18px;
        font-weight: 600;
        box-shadow: 0 8px 20px rgba(0,0,0,0.05);
        transition: all 0.25s ease;
        position: relative;
        overflow: hidden;
    }

        .dash-card::before {
            content: "";
            position: absolute;
            width: 130px;
            height: 130px;
            background: #e8f9f0;
            border-radius: 50%;
            top: -40px;
            right: -40px;
        }

    .dash-icon {
        font-size: 30px;
        margin-bottom: 10px;
        z-index: 1;
    }

    .dash-card span {
        z-index: 1;
    }

    .dash-card:hover {
        transform: translateY(-6px) scale(1.02);
        box-shadow: 0 14px 30px rgba(0,0,0,0.1);
        border-color: #bde8cd;
    }

        .dash-card:hover .dash-icon {
            transform: scale(1.2);
        }
</style>

<div class="dashboard-header">
    <div class="dashboard-title">🌱 Contributor Dashboard</div>
    <div class="dashboard-sub">Create and manage shelter information</div>
</div>

<div class="dashboard-grid">

    <a href="/Contributor/AddShelter" class="dash-card">
        <div class="dash-icon">➕</div>
        <span>Add Shelter</span>
    </a>

    <a href="/Contributor/MyShelters" class="dash-card">
        <div class="dash-icon">🏠</div>
        <span>My Shelters</span>
    </a>

</div>