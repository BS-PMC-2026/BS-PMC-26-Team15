<style>
    .container {
        max-width: 100% !important;
        padding: 0 !important;
        margin: 0 !important;
    }

    body {
        background: linear-gradient(135deg, #f8fbfc 0%, #eef8fa 45%, #fff5f3 100%);
        padding: 0 !important;
    }

    :root {
        --brand: #4bbfd3;
        --brand-mid: #35a8be;
        --brand-pale: #d8f4f9;
        --dark-red: #7f1d1d;
        --soft-red: #fee2e2;
        --text-primary: #111827;
        --text-secondary: #6b7280;
        --border-mid: rgba(75,191,211,.35);
    }

    .db-wrapper {
        width: 100%;
        min-height: 100vh;
        padding: 4rem 7rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .db-hero {
        display: grid;
        grid-template-columns: 1.1fr .9fr;
        gap: 3rem;
        align-items: center;
        margin-bottom: 3rem;
    }

    .db-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-family: 'DM Mono', monospace;
        font-size: 12px;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--dark-red);
        border: 1px solid rgba(127,29,29,.2);
        background: var(--soft-red);
        padding: 8px 16px;
        border-radius: 100px;
        width: fit-content;
        margin-bottom: 1.4rem;
    }

    .db-badge-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--dark-red);
        animation: dbPulse 2s ease-in-out infinite;
    }

    .db-title {
        font-family: 'DM Sans', sans-serif;
        font-size: clamp(3rem, 6vw, 5.5rem);
        font-weight: 800;
        letter-spacing: -.06em;
        line-height: .95;
        color: var(--text-primary);
        margin-bottom: 1rem;
    }

        .db-title span {
            color: var(--brand);
        }

    .db-sub {
        font-family: 'DM Sans', sans-serif;
        font-size: 1.2rem;
        color: var(--text-secondary);
        line-height: 1.7;
        max-width: 650px;
    }

    .db-info-box {
        background: #ffffff;
        border: 1px solid rgba(127,29,29,.15);
        border-radius: 28px;
        padding: 2.4rem;
        box-shadow: 0 25px 60px rgba(17,24,39,.08);
        position: relative;
        overflow: hidden;
    }

        .db-info-box::before {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at top right, rgba(224,59,43,.18), transparent 45%);
            pointer-events: none;
        }

    .db-info-title {
        font-family: 'DM Sans', sans-serif;
        font-size: 1.45rem;
        font-weight: 700;
        margin-bottom: .8rem;
        color: var(--dark-red);
        position: relative;
    }

    .db-info-text {
        font-family: 'DM Sans', sans-serif;
        color: var(--text-secondary);
        font-size: 1rem;
        line-height: 1.7;
        position: relative;
    }

    .db-stats {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
        margin-top: 1.8rem;
        position: relative;
    }

    .db-stat {
        background: #f9fafb;
        border: 1px solid #eef2f7;
        border-radius: 18px;
        padding: 1.1rem;
    }

        .db-stat strong {
            display: block;
            font-size: 1.6rem;
            color: var(--text-primary);
            font-family: 'DM Sans', sans-serif;
        }

        .db-stat span {
            font-size: .82rem;
            color: var(--text-secondary);
            font-family: 'DM Sans', sans-serif;
        }

    .db-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(320px, 1fr));
        gap: 1.7rem;
    }

    .db-card {
        min-height: 260px;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 1.2rem;
        background: rgba(255,255,255,.92);
        border: 1px solid var(--border-mid);
        border-radius: 26px;
        padding: 2.4rem;
        text-decoration: none;
        color: var(--text-primary);
        transition: transform .2s, box-shadow .2s, border-color .2s;
        position: relative;
        overflow: hidden;
        box-shadow: 0 18px 45px rgba(75,191,211,.10);
    }

        .db-card::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(75,191,211,.16), transparent 55%);
            opacity: 0;
            transition: opacity .2s;
        }

        .db-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 25px 65px rgba(75,191,211,.22);
            border-color: var(--brand);
            text-decoration: none;
            color: var(--text-primary);
        }

            .db-card:hover::before {
                opacity: 1;
            }

    .db-icon {
        width: 68px;
        height: 68px;
        border-radius: 20px;
        background: var(--brand-pale);
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
    }

        .db-icon.red {
            background: var(--soft-red);
        }

        .db-icon svg {
            width: 32px;
            height: 32px;
            stroke: var(--brand);
            fill: none;
            stroke-width: 2;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

        .db-icon.red svg {
            stroke: var(--dark-red);
        }

    .db-card-title {
        font-family: 'DM Sans', sans-serif;
        font-size: 1.6rem;
        font-weight: 700;
        margin: 0 0 .5rem;
    }

    .db-card-desc {
        font-family: 'DM Sans', sans-serif;
        font-size: 1rem;
        color: var(--text-secondary);
        margin: 0;
        line-height: 1.7;
        max-width: 430px;
    }

    .db-card-arrow {
        margin-top: auto;
        display: flex;
        align-items: center;
        gap: 7px;
        font-size: .95rem;
        font-weight: 700;
        color: var(--brand);
        font-family: 'DM Sans', sans-serif;
        position: relative;
    }

        .db-card-arrow svg {
            width: 18px;
            height: 18px;
            stroke: var(--brand);
            fill: none;
            stroke-width: 2;
            transition: transform .15s;
        }

    .db-card:hover .db-card-arrow svg {
        transform: translateX(5px);
    }

    .db-fade {
        animation: dbFadeUp .5s ease both;
    }

    @@keyframes dbPulse {
        0%, 100% {
            opacity: 1;
            transform: scale(1);
        }

        50% {
            opacity: .45;
            transform: scale(.65);
        }
    }

    @@keyframes dbFadeUp {
        from {
            opacity: 0;
            transform: translateY(14px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@media (max-width: 900px) {
        .db-wrapper {
            padding: 2rem;
            justify-content: flex-start;
        }

        .db-hero {
            grid-template-columns: 1fr;
        }

        .db-grid {
            grid-template-columns: 1fr;
        }

        .db-stats {
            grid-template-columns: 1fr;
        }
    }
</style>

<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />

