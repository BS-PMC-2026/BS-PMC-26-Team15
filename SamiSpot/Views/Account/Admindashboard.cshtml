@{
    ViewData["Title"] = "Admin Dashboard";
}

<style>
    body {
        background: #f4fbfd;
    }

    .dashboard-header {
        text-align: center;
        margin-top: 25px;
        margin-bottom: 10px;
    }

    .dashboard-title {
        font-size: 34px;
        font-weight: 700;
        color: #2c4a52;
    }

    .dashboard-sub {
        color: #5a7c84;
        margin-top: 5px;
    }

    .dashboard-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
        gap: 22px;
        padding: 40px;
    }

    .dash-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 150px;
        background: linear-gradient(135deg, #ffffff, #eaf9fc);
        border-radius: 20px;
        border: 1px solid #d6f2f7;
        text-decoration: none;
        color: #2c4a52;
        font-size: 18px;
        font-weight: 600;
        box-shadow: 0 8px 20px rgba(0,0,0,0.06);
        transition: all 0.25s ease;
        position: relative;
        overflow: hidden;
    }

        .dash-card::before {
            content: "";
            position: absolute;
            width: 120px;
            height: 120px;
            background: #eaf9fc;
            border-radius: 50%;
            top: -40px;
            right: -40px;
            z-index: 0;
        }

        .dash-card span {
            position: relative;
            z-index: 1;
            margin-top: 6px;
        }

    .dash-icon {
        font-size: 28px;
        margin-bottom: 8px;
    }

    .dash-card:hover {
        transform: translateY(-6px) scale(1.02);
        box-shadow: 0 14px 30px rgba(0,0,0,0.1);
        border-color: #bdebf3;
    }

        .dash-card:hover .dash-icon {
            transform: scale(1.2);
        }
</style>

<div class="dashboard-header">
    <div class="dashboard-title">👑 Admin Dashboard</div>
    <div class="dashboard-sub">Manage the system, users, and shelters</div>
    <div class="alert alert-danger">
        Failed to load admin dashboard. Please try again.
    </div>
</div>

<div class="dashboard-grid">

    <a href="/Admin/ManageUsers" class="dash-card">
        <div class="dash-icon">👥</div>
        <span>Manage Users</span>
    </a>

    <a href="/Admin/PendingShelters" class="dash-card">
        <div class="dash-icon">⏳</div>
        <span>Pending Approvals</span>
    </a>

    <a href="/Admin/AllShelters" class="dash-card">
        <div class="dash-icon">🏠</div>
        <span>All Shelters</span>
    </a>

    <a href="/Admin/Contributors" class="dash-card">
        <div class="dash-icon">🛠️</div>
        <span>Manage Contributors</span>
    </a>

</div>