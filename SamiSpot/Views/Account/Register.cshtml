@model SamiSpot.ViewModels.RegisterViewModel

<style>
    body {
        background: linear-gradient(135deg, #eaf9fc, #f4fbfd);
    }

    .auth-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 90vh;
        padding: 20px;
    }

    .auth-card {
        background: white;
        border-radius: 28px;
        padding: 40px 35px;
        width: 100%;
        max-width: 420px;
        box-shadow: 0 20px 50px rgba(0,0,0,0.08);
        border: 1px solid #d6f2f7;
    }

    .auth-title {
        font-size: 30px;
        font-weight: 800;
        color: #2c4a52;
        margin-bottom: 25px;
        text-align: center;
    }

    .form-label {
        font-weight: 700;
        color: #2c4a52;
        margin-bottom: 6px;
    }

    .form-control {
        border-radius: 14px;
        padding: 10px 12px;
        border: 1px solid #d6f2f7;
        transition: 0.2s;
    }

        .form-control:focus {
            border-color: #4bbfd3;
            box-shadow: 0 0 0 2px rgba(75,191,211,0.15);
        }

    .auth-btn {
        width: 100%;
        border-radius: 25px;
        padding: 12px;
        font-weight: 800;
        background: linear-gradient(135deg, #4bbfd3, #36aeca);
        border: none;
        transition: 0.2s;
    }

        .auth-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(75,191,211,0.3);
        }

    .auth-footer {
        text-align: center;
        margin-top: 18px;
        font-size: 14px;
    }

        .auth-footer a {
            color: #36aeca;
            font-weight: 700;
            text-decoration: none;
        }

            .auth-footer a:hover {
                text-decoration: underline;
            }

    .password-note {
        font-size: 12px;
        color: #5a7c84;
        margin-top: -5px;
        margin-bottom: 15px;
    }
</style>

<div class="auth-container">
    <div class="auth-card">

        <h3 class="auth-title">Create Account</h3>

        <form asp-action="Register" method="post">

            @if (ViewBag.ReturnUrl != null)
            {
                <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
            }

            <div class="mb-3">
                <label class="form-label">Username</label>
                <input asp-for="UserName" class="form-control" placeholder="Enter username..." />
            </div>

            <div class="mb-3">
                <label class="form-label">Email</label>
                <input asp-for="Email" class="form-control" placeholder="Enter email..." />
            </div>

            <div class="mb-3">
                <label class="form-label">Password</label>
                <input asp-for="Password" type="password" class="form-control" placeholder="Enter password..." />
            </div>

            <div class="mb-3">
                <label class="form-label">Confirm Password</label>
                <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Confirm password..." />
            </div>

            <div class="mb-3">
                <label class="form-label">Account Type</label>
                <select asp-for="RoleType" class="form-control">
                    <option value="User">User</option>
                    <option value="Contributor">Contributor</option>
                </select>
            </div>

            <p class="password-note">
                Password must be at least 8 characters, include uppercase, lowercase and number.
            </p>

            <button type="submit" class="btn auth-btn">Sign Up</button>

        </form>

        <div class="auth-footer">
            Already have an account?
            <a href="/Account/Login">Login</a>
        </div>

    </div>
</div>