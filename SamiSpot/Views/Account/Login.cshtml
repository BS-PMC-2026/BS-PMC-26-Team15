@model SamiSpot.ViewModels.LoginViewModel

<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        background: #0d1117;
        background-image: url('https://images.unsplash.com/photo-1477959858617-67f85cf4f1df?w=1600&auto=format&fit=crop&q=80');
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
        position: relative;
    }

        body::before {
            content: "";
            position: fixed;
            inset: 0;
            background: rgba(10, 15, 22, 0.72);
            z-index: 0;
            pointer-events: none;
        }

    .auth-container {
        position: relative;
        z-index: 1;
        min-height: 78vh;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 10px;
    }

    .auth-card {
        width: 100%;
        max-width: 420px;
        background: rgba(18, 26, 32, 0.82);
        backdrop-filter: blur(16px);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 24px;
        padding: 38px;
        box-shadow: 0 24px 60px rgba(0,0,0,0.5);
    }

    .auth-title {
        font-size: 34px;
        font-weight: 800;
        color: #ffffff;
        text-align: center;
        margin-bottom: 10px;
    }

    .auth-subtitle {
        text-align: center;
        color: rgba(255,255,255,0.45);
        font-size: 15px;
        margin-bottom: 28px;
    }

    .form-label {
        font-size: 14px;
        font-weight: 700;
        color: rgba(255,255,255,0.75);
        margin-bottom: 10px;
    }

    .input-box {
        position: relative;
        margin-bottom: 20px;
    }

    .form-control {
        height: 54px;
        border-radius: 14px;
        border: 1.5px solid rgba(255,255,255,0.12);
        padding-left: 52px;
        padding-right: 52px;
        font-size: 15px;
        color: #ffffff;
        background: rgba(255,255,255,0.07);
        box-shadow: none;
        transition: border-color 0.2s, background 0.2s;
    }

        .form-control:focus {
            border-color: #4bbfd3;
            background: rgba(255,255,255,0.1);
            box-shadow: none;
            color: #ffffff;
            outline: none;
        }

        .form-control::placeholder {
            color: rgba(255,255,255,0.3);
        }

    .input-icon {
        position: absolute;
        top: 50%;
        left: 18px;
        transform: translateY(-50%);
        color: rgba(255,255,255,0.35);
        font-size: 20px;
    }

    .eye-icon {
        position: absolute;
        top: 50%;
        right: 18px;
        transform: translateY(-50%);
        color: rgba(255,255,255,0.35);
        font-size: 20px;
        cursor: pointer;
        transition: color 0.2s;
    }

        .eye-icon:hover {
            color: rgba(255,255,255,0.7);
        }

    .forgot-password {
        text-align: right;
        margin-top: -2px;
        margin-bottom: 22px;
    }

        .forgot-password a {
            color: #4bbfd3;
            text-decoration: none;
            font-size: 14px;
            font-weight: 600;
        }

            .forgot-password a:hover {
                color: #7eeaf7;
            }

    .auth-btn {
        width: 100%;
        height: 54px;
        border: none;
        border-radius: 14px;
        background: #eb7445;
        color: white;
        font-size: 18px;
        font-weight: 700;
        transition: 0.2s;
        box-shadow: 0 8px 24px rgba(235,116,69,0.3);
        cursor: pointer;
    }

        .auth-btn:hover {
            background: #df6433;
            transform: translateY(-2px);
            box-shadow: 0 12px 28px rgba(235,116,69,0.4);
        }

    .divider {
        display: flex;
        align-items: center;
        margin: 24px 0;
    }

        .divider::before,
        .divider::after {
            content: "";
            flex: 1;
            height: 1px;
            background: rgba(255,255,255,0.1);
        }

        .divider span {
            margin: 0 14px;
            color: rgba(255,255,255,0.35);
            font-size: 14px;
        }

    .create-account {
        text-align: center;
        font-size: 15px;
        color: rgba(255,255,255,0.45);
    }

        .create-account a {
            color: #ffffff;
            text-decoration: none;
            font-weight: 700;
        }

            .create-account a:hover {
                color: #4bbfd3;
            }

    .text-danger {
        color: #f87171 !important;
    }
</style>

<div class="auth-container">

    <div class="auth-card">

        <h1 class="auth-title">Login</h1>

        <p class="auth-subtitle">
            Welcome back, stay safe and informed.
        </p>

        <form asp-action="Login" method="post">

            <input type="hidden"
                   name="returnUrl"
                   value="@Context.Request.Query["returnUrl"]" />

            <div asp-validation-summary="All"
                 class="text-danger mb-4 text-center">
            </div>

            <!-- EMAIL -->
            <div class="mb-4">

                <label class="form-label">Email</label>

                <div class="input-box">
                    <i class="bi bi-envelope input-icon"></i>
                    <input asp-for="Email"
                           class="form-control"
                           placeholder="Enter your email" />
                </div>

                <span asp-validation-for="Email" class="text-danger"></span>

            </div>

            <!-- PASSWORD -->
            <div class="mb-3">

                <label class="form-label">Password</label>

                <div class="input-box">
                    <i class="bi bi-lock input-icon"></i>
                    <input asp-for="Password"
                           type="password"
                           class="form-control"
                           id="passwordInput"
                           placeholder="Enter your password" />
                    <span class="eye-icon" onclick="togglePassword()">
                        <i id="eyeIcon" class="bi bi-eye-slash"></i>
                    </span>
                </div>

                <span asp-validation-for="Password" class="text-danger"></span>

            </div>

            <div class="forgot-password">
                <a href="#">Forgot password?</a>
            </div>

            <button type="submit" class="auth-btn">Login</button>

        </form>

        <div class="divider"><span>or</span></div>

        <div class="create-account">
            Don't have an account?
            <a href="/Account/Register">Create new account</a>
        </div>

    </div>

</div>

<script>
    function togglePassword() {
        const input = document.getElementById("passwordInput");
        const eyeIcon = document.getElementById("eyeIcon");

        if (input.type === "password") {
            input.type = "text";
            eyeIcon.classList.remove("bi-eye-slash");
            eyeIcon.classList.add("bi-eye");
        } else {
            input.type = "password";
            eyeIcon.classList.remove("bi-eye");
            eyeIcon.classList.add("bi-eye-slash");
        }
    }
</script>