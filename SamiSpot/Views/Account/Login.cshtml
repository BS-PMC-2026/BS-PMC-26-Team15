@model SamiSpot.ViewModels.LoginViewModel

<style>
    body {
        background: #f4fbfd;
    }

    .auth-container {
        min-height: 82vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 30px 15px;
    }

    .auth-card {
        width: 100%;
        max-width: 460px;
        background: #ffffff;
        border: 1px solid #d6f2f7;
        border-radius: 26px;
        padding: 40px;
        box-shadow: 0 14px 35px rgba(0,0,0,0.07);
        position: relative;
        overflow: hidden;
    }

        .auth-card::before {
            content: "";
            position: absolute;
            top: -80px;
            right: -80px;
            width: 180px;
            height: 180px;
            background: #eaf9fc;
            border-radius: 50%;
        }

    .auth-badge {
        display: inline-block;
        background: #eaf9fc;
        border: 1px solid #d6f2f7;
        color: #2c4a52;
        border-radius: 30px;
        padding: 7px 15px;
        font-weight: 600;
        margin-bottom: 16px;
        position: relative;
    }

    .auth-title {
        color: #2c4a52;
        font-weight: 700;
        font-size: 34px;
        margin-bottom: 6px;
        position: relative;
    }

    .auth-subtitle {
        color: #3c5c63;
        margin-bottom: 28px;
        position: relative;
    }

    .form-label {
        color: #2c4a52;
        font-weight: 600;
    }

    .form-control {
        border-radius: 12px;
        border: 1px solid #d6f2f7;
        padding: 12px 14px;
    }

        .form-control:focus {
            border-color: #4bbfd3;
            box-shadow: 0 0 0 0.2rem rgba(75,191,211,0.18);
        }

    .show-btn {
        border-radius: 12px;
        border: 1px solid #d6f2f7;
        background: #eaf9fc;
        color: #2c4a52;
    }

    .auth-btn {
        width: 100%;
        background: #4bbfd3;
        border: none;
        border-radius: 30px;
        padding: 12px;
        font-weight: 600;
        margin-top: 10px;
        box-shadow: 0 8px 18px rgba(75,191,211,0.25);
        transition: all 0.25s ease;
    }

        .auth-btn:hover {
            background: #36aeca;
            transform: translateY(-2px);
        }

    .create-link {
        color: #2c4a52;
        font-weight: 600;
        text-decoration: none;
    }

        .create-link:hover {
            color: #4bbfd3;
        }
</style>

<div class="auth-container">
    <div class="auth-card">

        <div class="text-center">
            <div class="auth-badge">🛡️ SamiSpot secure access</div>
            <h3 class="auth-title">Login</h3>
            <p class="auth-subtitle">Welcome back, stay safe and informed.</p>
        </div>

        <form asp-action="Login" method="post">

            <input type="hidden" name="returnUrl" value="@Context.Request.Query["returnUrl"]" />

            <!-- EMAIL -->
            <div class="mb-3">
                <label class="form-label">Email</label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <!-- PASSWORD -->
            <div class="mb-3">
                <label class="form-label">Password</label>
                <div class="input-group">
                    <input asp-for="Password" type="password" class="form-control" id="passwordInput" />
                    <button type="button" class="btn show-btn" onclick="togglePassword()">👁️</button>
                </div>
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-success auth-btn">Login</button>

        </form>

        <div class="text-center mt-4">
            <a href="/Account/Register" class="create-link">Create new account →</a>
        </div>

    </div>
</div>

<script>
    function togglePassword() {
        const input = document.getElementById("passwordInput");
        input.type = input.type === "password" ? "text" : "password";
    }
</script>