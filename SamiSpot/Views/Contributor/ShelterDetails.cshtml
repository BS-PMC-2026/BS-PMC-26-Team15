@model SamiSpot.Models.ContributorShelter

@{
    ViewData["Title"] = "Shelter Details";
}

<div class="container mt-4">
    <h2 class="mb-4">Shelter Details</h2>

    <div class="card shadow-sm p-4">

        <h3 class="mb-3">@Model.Name</h3>

        <p><strong>Address:</strong> @Model.Address</p>

        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <p><strong>Description:</strong> @Model.Description</p>
        }

        <p>
            <strong>Status:</strong>
            @if (Model.Status == "Approved")
            {
                <span class="badge bg-success">Approved</span>
            }
            else if (Model.Status == "Pending")
            {
                <span class="badge bg-warning text-dark">Pending</span>
            }
            else
            {
                <span class="badge bg-danger">Rejected</span>
            }
        </p>

        <p><strong>Date Added:</strong> @Model.CreatedAt.ToString("dd/MM/yyyy")</p>

        @if (Model.Size != null)
        {
            <p><strong>Capacity:</strong> @Model.Size people</p>
        }

        <p>
            <strong>Available:</strong>
            @(Model.IsAvailable ? "Yes" : "No")
        </p>

        <p><strong>Location:</strong> @Model.Latitude , @Model.Longitude</p>

        <hr />

        <h5 class="mb-3">Images</h5>

        @if (Model.Images != null && Model.Images.Count > 0)
        {
            <div class="row">
                @foreach (var image in Model.Images)
                {
                    <div class="col-md-4 mb-3">
                        <img src="@image.ImageUrl"
                             class="img-fluid rounded shadow-sm"
                             style="height:220px; width:100%; object-fit:cover;" />
                    </div>
                }
            </div>
        }
        else
        {
            <p>No images uploaded.</p>
        }

        <hr />

        <div class="mt-3">
            <a href="/Contributor/MyShelters" class="btn btn-secondary">Back</a>
        </div>

    </div>
</div>