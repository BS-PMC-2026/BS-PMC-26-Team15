@model List<SamiSpot.Models.ContributorShelter>

@{
    ViewData["Title"] = "My Shelters";
}

<div class="container mt-4">
    <h2 class="mb-4">My Shelters</h2>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info">You haven't added any shelters yet. <a href="/Contributor/AddShelter">Add one now!</a></div>
    }
    else
    {
        <table class="table table-bordered table-hover">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Shelter Name</th>
                    <th>Status</th>
                    <th>Date Added</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var shelter in Model)
                {
                    <tr>
                        <td>@shelter.Id</td>
                        <td>@shelter.Name</td>
                        <td>
                            @if (shelter.Status == "Approved")
                            {
                                <span class="badge bg-success">Approved</span>
                            }
                            else if (shelter.Status == "Pending")
                            {
                                <span class="badge bg-warning text-dark">Pending</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Rejected</span>
                            }
                        </td>
                        <td>@shelter.CreatedAt.ToString("dd/MM/yyyy")</td>
                        <td>
                            <a href="/Contributor/ShelterDetails/@shelter.Id" class="btn btn-sm btn-primary">View</a>
                            <a href="/Contributor/EditShelter/@shelter.Id" class="btn btn-sm btn-warning">Edit</a>
                            <form action="/Contributor/DeleteShelter/@shelter.Id" method="post" style="display:inline"
                                  onsubmit="return confirm('Are you sure you want to delete this shelter?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <a href="/Contributor/AddShelter" class="btn btn-success mt-2">+ Add New Shelter</a>
</div>