@model List<SamiSpot.Models.ContributorShelter>

@{
    ViewData["Title"] = "My Shelters";
}

<style>
    body {
        background: #f4fbfd;
    }

    .my-shelters-page {
        width: 100%;
        padding: 40px 60px;
        margin: 0;
    }
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
        flex-wrap: wrap;
        gap: 15px;
    }

    .page-title {
        font-size: 38px;
        font-weight: 800;
        color: #2c4a52;
        margin: 0;
    }

    .page-subtitle {
        color: #5a7c84;
        font-size: 17px;
        margin-top: 5px;
    }

    .add-btn {
        background: #4bbfd3;
        color: white;
        border-radius: 30px;
        padding: 12px 24px;
        text-decoration: none;
        font-weight: 700;
        box-shadow: 0 8px 18px rgba(75,191,211,0.25);
        transition: 0.2s;
    }

        .add-btn:hover {
            background: #36aeca;
            color: white;
            transform: translateY(-2px);
        }

    .table-scroll {
        width: 100%;
        overflow-x: auto;
    }

    .custom-table {
        width: 100%;
        border-collapse: collapse;
    }

        .custom-table thead th {
            background: #eaf9fc;
            color: #2c4a52;
            font-weight: 800;
            padding: 16px;
            border-bottom: 2px solid #cdeff5;
        }

        .custom-table tbody tr {
            background: #ffffff;
            transition: all 0.2s ease;
        }

            .custom-table tbody tr:hover {
                background: #f9feff;
                box-shadow: 0 6px 18px rgba(0,0,0,0.05);
            }

        .custom-table tbody td {
            background: #ffffff;
            padding: 18px;
            color: #3c5c63;
            border-bottom: 1px solid #dceff3;
            vertical-align: middle;
        }

    .id-cell {
        font-weight: 800;
        color: #4bbfd3;
    }

    .action-btn {
        border-radius: 20px;
        padding: 6px 14px;
        font-weight: 700;
        margin-right: 6px;
    }

    .empty-box {
        background: #eaf9fc;
        border-left: 5px solid #4bbfd3;
        padding: 20px;
        color: #2c4a52;
        border-radius: 10px;
    }

    @@media (max-width: 768px) {
        .my-shelters-page {
            padding: 25px;
        }

        .custom-table {
            min-width: 700px;
        }
    }
</style>

<div class="my-shelters-page">

    <div class="page-header">
        <div>
            <h2 class="page-title"> My Shelters</h2>
            <p class="page-subtitle">
                Track, update, and manage the shelters you submitted.
            </p>
        </div>

        <a href="/Contributor/AddShelter" class="add-btn">+ Add Shelter</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    @if (Model == null || !Model.Any())
    {
        <div class="empty-box">
            You haven't added any shelters yet.
            <a href="/Contributor/AddShelter">Add one now!</a>
        </div>
    }
    else
    {
        <div class="table-scroll">
            <table class="custom-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Shelter Name</th>
                        <th>Status</th>
                        <th>Date Added</th>
                        <th>Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var shelter in Model)
                    {
                        <tr>
                            <td class="id-cell">@shelter.Id</td>

                            <td>@shelter.Name</td>

                            <td>
                                @if (shelter.Status == "Approved")
                                {
                                    <span class="badge bg-success">Approved</span>
                                }
                                else if (shelter.Status == "Pending")
                                {
                                    <span class="badge bg-warning text-dark">Pending</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Rejected</span>
                                }
                            </td>

                            <td>@shelter.CreatedAt.ToString("dd/MM/yyyy")</td>

                            <td>
                                <a href="/Contributor/ShelterDetails/@shelter.Id"
                                   class="btn btn-sm btn-primary action-btn">View</a>

                                <a href="/Contributor/EditShelter/@shelter.Id"
                                   class="btn btn-sm btn-warning action-btn">Edit</a>

                                <form action="/Contributor/DeleteShelter/@shelter.Id"
                                      method="post"
                                      style="display:inline"
                                      onsubmit="return confirm('Are you sure you want to delete this shelter?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit"
                                            class="btn btn-sm btn-danger action-btn">
                                        Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

</div>